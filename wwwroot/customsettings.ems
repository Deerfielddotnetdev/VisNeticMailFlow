																		<tr>
																			<td>
																				<select name="ExcType">
																					<option value="1" selected="true">Closed</option>
																					<option value="2">Open</option>
																				</select>
																			</td>
																			<td>
																				<input name="ExcDesc" type="text" size="25" maxlength="250" />
																			</td>
																			<td id="dateExcCell">
																				
																					<script type="text/javascript">
																						
																						var dataDate = "";
																						var start = null;
																						
																						if(dataDate.length)
																							start = new Date(dataDate);
																						else
																						{
																							start = new Date();
																							start.setDate(start.getDate());
																						}
																							
																						var objExcDate = new DatePicker(start);
																						document.getElementById("dateExcCell").appendChild(objExcDate.create("dtExcObj"));
																					</script>
																				
																			</td>
																			<td>
																				<select name="ExcHrStart">
																					<option>
																						<xsl:attribute name="value">1</xsl:attribute>
																						01
																					</option>
																					<option>
																						<xsl:attribute name="value">2</xsl:attribute>
																						02
																					</option>
																					<option>
																						<xsl:attribute name="value">3</xsl:attribute>
																						03
																					</option>
																					<option>
																						<xsl:attribute name="value">4</xsl:attribute>
																						04
																					</option>
																					<option>
																						<xsl:attribute name="value">5</xsl:attribute>
																						05
																					</option>
																					<option>
																						<xsl:attribute name="value">6</xsl:attribute>
																						06
																					</option>
																					<option>
																						<xsl:attribute name="value">7</xsl:attribute>
																						07
																					</option>
																					<option>
																						<xsl:attribute name="value">8</xsl:attribute>
																						<xsl:attribute name="selected">true</xsl:attribute>
																						08
																					</option>
																					<option>
																						<xsl:attribute name="value">9</xsl:attribute>
																						09
																					</option>
																					<option>
																						<xsl:attribute name="value">10</xsl:attribute>
																						10
																					</option>
																					<option>
																						<xsl:attribute name="value">11</xsl:attribute>
																						11
																					</option>
																					<option>
																						<xsl:attribute name="value">12</xsl:attribute>
																						12
																					</option>
																				</select>
																				<b>:</b> 
																				<select name="ExcMinStart">
																					<option>
																						<xsl:attribute name="value">0</xsl:attribute>
																						<xsl:attribute name="selected">true</xsl:attribute>
																						00
																					</option>
																					<option>
																						<xsl:attribute name="value">15</xsl:attribute>
																						15
																					</option>
																					<option>
																						<xsl:attribute name="value">30</xsl:attribute>
																						30
																					</option>
																					<option>
																						<xsl:attribute name="value">45</xsl:attribute>
																						45
																					</option>
																				</select>
																				<select name="ExcAmPmStart">
																					<option>
																						<xsl:attribute name="value">1</xsl:attribute>
																						<xsl:attribute name="selected">true</xsl:attribute>
																						AM
																					</option>
																					<option>
																						<xsl:attribute name="value">2</xsl:attribute>
																						PM
																					</option>
																				</select>
																				</td>
																				<td>
																				<select name="ExcHrEnd">
																					<option>
																						<xsl:attribute name="value">1</xsl:attribute>
																						01
																					</option>
																					<option>
																						<xsl:attribute name="value">2</xsl:attribute>
																						02
																					</option>
																					<option>
																						<xsl:attribute name="value">3</xsl:attribute>
																						03
																					</option>
																					<option>
																						<xsl:attribute name="value">4</xsl:attribute>
																						04
																					</option>
																					<option>
																						<xsl:attribute name="value">5</xsl:attribute>
																						<xsl:attribute name="selected">true</xsl:attribute>
																						05
																					</option>
																					<option>
																						<xsl:attribute name="value">6</xsl:attribute>
																						06
																					</option>
																					<option>
																						<xsl:attribute name="value">7</xsl:attribute>
																						07
																					</option>
																					<option>
																						<xsl:attribute name="value">8</xsl:attribute>
																						08
																					</option>
																					<option>
																						<xsl:attribute name="value">9</xsl:attribute>
																						09
																					</option>
																					<option>
																						<xsl:attribute name="value">10</xsl:attribute>
																						10
																					</option>
																					<option>
																						<xsl:attribute name="value">11</xsl:attribute>
																						11
																					</option>
																					<option>
																						<xsl:attribute name="value">12</xsl:attribute>
																						12
																					</option>
																				</select>
																				<b>:</b> 
																				<select name="ExcMinEnd">
																					<option>
																						<xsl:attribute name="value">0</xsl:attribute>
																						<xsl:attribute name="selected">true</xsl:attribute>
																						00
																					</option>
																					<option>
																						<xsl:attribute name="value">15</xsl:attribute>
																						15
																					</option>
																					<option>
																						<xsl:attribute name="value">30</xsl:attribute>
																						30
																					</option>
																					<option>
																						<xsl:attribute name="value">45</xsl:attribute>
																						45
																					</option>
																				</select>
																				<select name="ExcAmPmEnd">
																					<option>
																						<xsl:attribute name="value">1</xsl:attribute>
																						AM
																					</option>
																					<option>
																						<xsl:attribute name="value">2</xsl:attribute>
																						<xsl:attribute name="selected">true</xsl:attribute>
																						PM
																					</option>
																				</select>
																				</td>
																				<td>
																				<input type="button" name="btnAddExc" class="childControlBtn" value=" Add " onclick="addExc();"/>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="6" style="padding-top:20px;">
																				<table id="ExceptionTable" border="1" cellpadding="2" cellspacing="0">
																					<tr>
																						<td>
																							Type
																						</td>
																						<td>
																							Description
																						</td>
																						<td>
																							Start Time
																						</td>
																						<td>
																							End Time
																						</td>
																						<td>
																							<xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;
																						</td>
																					</tr>
																				<xsl:for-each select="root/Exceptions/Exception">
																					<xsl:variable name="Id" select="@ID"/>
																					<xsl:variable name="TypeId" select="@TypeID"/>
																					<tr id="{$Id}">
																						<td>
																							<xsl:choose>
																								<xsl:when test='@TypeID = "1"'>Closed</xsl:when>
																								<xsl:otherwise>Open</xsl:otherwise>
																							</xsl:choose>
																						</td>
																						<td>
																							<xsl:value-of select='@Description'/>
																						</td>
																						<td>
																							<xsl:value-of select='@TimeStart'/>
																						</td>
																						<td>
																							<xsl:value-of select='@TimeEnd'/>
																						</td>
																						<td>
																							<input type="button" name="btnDelExc" class="childControlBtn" value="Delete" onclick="delExc({$Id});"/>
																						</td>
																					</tr>
																				</xsl:for-each>
																				</table>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
														</table>
													</td>
												</tr>
											</table>
										</td>						
									</tr>																				
								</table>
							</div>
							<div id="content3" style="overflow:auto;display:none;visibility:hidden;width:100%;height:100%;">
				  				<table style="width:100%;padding:10px;" border="0" cellspacing="0" cellpadding="0">
									<tr>
										<td>
											<table width="100%;" border="0" cellspacing="0" cellpadding="0">
												<tr>
													<td style="padding-right:10px;">
														<table cellspacing="0" border="0" width="100%">
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Scheduled Report Processing
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableScheduledReports" name="chkEnableScheduledReports" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableScheduledReports = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Enabled</span>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
														</table>
													</td>
												</tr>
											</table>
										</td>						
									</tr>																				
								</table>
							</div>	
							<div id="content4" style="overflow:auto;display:none;visibility:hidden;width:100%;height:100%;">
				  				<table style="width:100%;padding:10px;" border="0" cellspacing="0" cellpadding="0">
									<tr>
										<td>
											<table width="100%;" border="0" cellspacing="0" cellpadding="0">
												<tr>
													<td style="padding-right:10px;">
														<table cellspacing="0" border="0" width="100%">
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Ticket Search
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableGetOldestSearch" name="chkEnableGetOldestSearch" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableGetOldestSearch = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Enable unowned Ticket Search for Agents set to use GetOldest feature</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkRequireDate" name="chkRequireDate" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/RequireDate = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Require Date Range if Searching Body or Subject Contains</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<span>Default Database timeout (seconds) for ticket searches (Default:60): </span>
																				<input style="position:relative;left:37px;" name="txtDBTimeout" type="text" size="3" value="{root/customsettings/dbtimeout}" onkeydown="onDBTimeoutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	MAX Ticket Lock Time
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Maximum time (minutes) tickets can be locked (Default:60) (0=Infinity): </span>
																				<input style="position:relative;left:17px;" name="txtMaxTicketLockTime" type="text" size="3" value="{root/customsettings/maxTicketLockTime}" onkeydown="onLockTimeKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Ticket List Date
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input type="Radio" id="chkTicketListDate" name="chkTicketListDate" value="0" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/ticketListDate = '0'">
																					<xsl:attribute name="CHECKED">true</xsl:attribute>
																				</xsl:if>
																				</input><span>Utilize latest Ticket Open Date as Ticket List Date</span><br/>
																				<input type="Radio" id="chkTicketListDate" name="chkTicketListDate" value="1" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/ticketListDate = '1'">
																					<xsl:attribute name="CHECKED">true</xsl:attribute>
																				</xsl:if>
																				</input><span>Utilize latest Inbound/Outbound Message or Ticket Note as Ticket List Date</span><br/>
																				<input type="Radio" id="chkTicketListDate" name="chkTicketListDate" value="2" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/ticketListDate = '2'">
																					<xsl:attribute name="CHECKED">true</xsl:attribute>
																				</xsl:if>
																				</input><span>Utilize initial Inbound/Outbound Message or Ticket Note as Ticket List Date</span><br/>																				
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Inbound Message Date
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input type="Radio" id="MsgDate" name="MsgDate" value="0" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/MsgDate = '0'">
																					<xsl:attribute name="CHECKED">true</xsl:attribute>
																				</xsl:if>
																				</input><span>Utilize Date Received by System</span><br/>
																				<input type="Radio" id="MsgDate" name="MsgDate" value="1" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/MsgDate = '1'">
																					<xsl:attribute name="CHECKED">true</xsl:attribute>
																				</xsl:if>
																				</input><span>Utilize Message Date Header</span><br/>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Read/Unread Messages &amp; Notes
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input name="chkCutoffDate" type="checkbox" onclick="onChkCuttoffDateClick();">
																					<xsl:if test="/root/customsettings/usecufoffreaddate = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Only mark messages and notes read/unread after this date:</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<div id="divCutoff" onclick="onDBTimeoutKeyDown();">
																					<script type="text/javascript">
																						
																						var dataDate = "<xsl:value-of select='/root/customsettings/cufoffreaddate'/>";
																						var start = null;
																						
																						if(dataDate.length)
																							start = new Date(dataDate);
																						else
																						{
																							start = new Date();
																							start.setDate(start.getDate() - 30);
																						}
																							
																						objCreateTicklerDate = new DatePicker(start);
																						document.getElementById("divCutoff").appendChild(objCreateTicklerDate.create("dtCutOffObj"));
																					</script>
																				</div>
																			</td>
																		</tr>
																		<tr><td height="10" colspan="2"><xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;</td></tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableMyTickets" name="chkEnableMyTickets" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableMyTickets = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Enable left menu unread ticket counts for "My Tickets"</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnablePublicTicketBoxes" name="chkEnablePublicTicketBoxes" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enablePublicTicketBoxes = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Enable left menu unread ticket counts for "Public Ticket Boxes"</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableAgentViews" name="chkEnableAgentViews" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableAgentViews = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Enable left menu unread ticket counts for "Agent Views"</span>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Ticket Tracking
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input type="Radio" id="chkTicketTracking" name="chkTicketTracking" value="0" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/TicketTracking = '0'">
																					<xsl:attribute name="CHECKED">true</xsl:attribute>
																				</xsl:if>
																				</input><span>Place Ticket Tracking Data in Subject of Outbound Messages</span><br/>
																				<input type="Radio" id="chkTicketTracking" name="chkTicketTracking" value="1" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/TicketTracking = '1'">
																					<xsl:attribute name="CHECKED">true</xsl:attribute>
																				</xsl:if>
																				</input><span>Place Ticket Tracking Data in Body of Outbound Messages</span><br/>
																				<input type="Radio" id="chkTicketTracking" name="chkTicketTracking" value="3" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/TicketTracking = '3'">
																					<xsl:attribute name="CHECKED">true</xsl:attribute>
																				</xsl:if>
																				</input><span>Place Ticket Tracking Data in Header of Outbound Messages</span><br/>
																				<input type="Radio" id="chkTicketTracking" name="chkTicketTracking" value="2" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/TicketTracking = '2'">
																					<xsl:attribute name="CHECKED">true</xsl:attribute>
																				</xsl:if>
																				</input><span>Do not add Ticket Tracking Data to Outbound Messages</span>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Ticket Assignment
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<span>Do not allow Manual Ticket Assignment to Agents with the following Status</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkOnline" name="chkOnline" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkOnline = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Online</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkAway" name="chkAway" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkAway = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Away</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkNotAvail" name="chkNotAvail" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkNotAvail = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Not Available</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkOffline" name="chkOffline" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkOffline = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Offline</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkOoo" name="chkOoo" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkOoo = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Out of Office</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;padding-top:10px;" valign="top">
																				<input id="chkAdminOr" name="chkAdminOr" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkAdminOr = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Always allow Administrators to Assign Tickets</span>
																			</td>
																		</tr>
																		<tr>
																			<td colspan="2" width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkAgentOr" name="chkAgentOr" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkAgentOr = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Always allow Agents to take Ownership of Tickets, regardless of their Status</span>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
														</table>
													</td>
												</tr>
											</table>
										</td>
									</tr>
								</table>
							</div>
							<div id="content5" style="overflow:auto;display:none;visibility:hidden;width:100%;height:100%;">
				  				<table style="width:100%;padding:10px;" border="0" cellspacing="0" cellpadding="0">
									<tr>
										<td>
											<table width="100%;" border="0" cellspacing="0" cellpadding="0">
												<tr>
													<td style="padding-right:10px;">
														<table cellspacing="0" border="0" width="100%">
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Message Composition
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table border="0" width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td style="padding-right:5px;width:100%;" valign="top">
																				<table>
																				<tr>
																				<td>
																					Close Ticket after Send:<xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;
																				</td>
																				<td>
																				<select name="CloseTicketAfterSend" onchange="updateSaveButton()">
																					<option value="2">
																					<xsl:if test="root/customsettings/CloseTicketAfterSend = '2'"><xsl:attribute name="selected">true</xsl:attribute></xsl:if>
																					Prompt</option>
																					<option value="0">
																					<xsl:if test="root/customsettings/CloseTicketAfterSend = '0'"><xsl:attribute name="selected">true</xsl:attribute></xsl:if>
																					No</option>
																					<option value="1">
																					<xsl:if test="root/customsettings/CloseTicketAfterSend = '1'"><xsl:attribute name="selected">true</xsl:attribute></xsl:if>
																					Yes</option>
																				</select>
																				</td>
																				<td>
																				<input type="button" name="btnApplyCTAS" class="childControlBtn" value="Apply Now To:" onclick="applyCTAS();"/>
																				<select name="AgentOrGroup1" onchange="switchSelect(this)">
																					<option value="Agent" selected="true">Agent</option>
																					<option value="Group">Group</option>
																				</select>
																				<select id="selectBox1" name="Agent1">
																				<option value="0">None</option>
																				<xsl:for-each select="/root/AgentNames/Agent">
																					<option value="{@ID}">
																					<xsl:value-of select="@Name"/>
																					</option>
																				</xsl:for-each>
																				</select>
																				</td>
																				</tr>
																				<tr>
																				<td>
																					Route Replies to Me:
																				</td>
																				<td>
																				<select name="AutoRouteToInbox" onchange="updateSaveButton()">
																					<option value="2">
																					<xsl:if test="root/customsettings/AutoRouteToInbox = '2'"><xsl:attribute name="selected">true</xsl:attribute></xsl:if>
																					Prompt</option>
																					<option value="0">
																					<xsl:if test="root/customsettings/AutoRouteToInbox = '0'"><xsl:attribute name="selected">true</xsl:attribute></xsl:if>
																					No</option>
																					<option value="1">
																					<xsl:if test="root/customsettings/AutoRouteToInbox = '1'"><xsl:attribute name="selected">true</xsl:attribute></xsl:if>
																					Yes</option>
																				</select>
																				</td>
																				<td>
																				<input type="button" name="btnApplyRRTM" class="childControlBtn" value="Apply Now To:" onclick="applyRRTM();"/>
																				<select name="AgentOrGroup2" onchange="switchSelect(this)">
																					<option value="Agent" selected="true">Agent</option>
																					<option value="Group">Group</option>
																				</select>
																				<select id="selectBox2" name="Agent2">
																				<option value="0">None</option>
																				<xsl:for-each select="/root/AgentNames/Agent">
																					<option value="{@ID}">
																					<xsl:value-of select="@Name"/>
																					</option>
																				</xsl:for-each>
																				</select>
																				</td>
																				</tr>
																				</table>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Spell Check Dictionaries
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top" colspan="4">
																				<span>Default Dictionary: </span>
																				<select name="DictionaryID" onchange="updateSaveButton()">
																					<xsl:for-each select="/root/Dictionaries/Dictionary">
																						<xsl:if test="@IsEnabled = '1'">
                                            <option>
																							<xsl:attribute name="value"><xsl:value-of select="@ID"/></xsl:attribute>
																							<xsl:if test="/root/customsettings/DictionaryID = @ID">
																							<xsl:attribute name="selected">true</xsl:attribute>
																							</xsl:if>
																							<xsl:value-of select="@Description"/>
																						</option>
																						</xsl:if>
                                          </xsl:for-each>
                                        </select>
																			</td>
																			</tr>
																			<tr>
																			<td width="100%" style="padding-right:5px;align:left;padding-top:10px;" valign="top">
																				<table>
																					<thead class="subSectionHeader" style="text-align:left;">
																						<th>Enabled</th>
																						<th>Description</th>
																						<th>TLX File</th>
																						<th>CLX File</th>
																					</thead>
																					<xsl:for-each select="/root/Dictionaries/Dictionary">
																					<tr>
																						<td>
																							<input id="chkDictionary{@ID}" name="chkDictionary{@ID}" type="checkbox" onclick="updateSaveButton();">
																								<xsl:if test="@IsEnabled = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																							</input>
																						</td>
																						<td>
																							<xsl:value-of select="@Description"/>
																						</td>
																						<td>
																							<input name="TlxFile{@ID}" id="TlxFile{@ID}" type="text" size="20" maxlength="20" value="{@TlxFile}" disabled="disabled" />
																						</td>
																						<td>
																							<input name="ClxFile{@ID}" id="ClxFile{@ID}" type="text" size="20" maxlength="20" value="{@ClxFile}" disabled="disabled" />
																						</td>
																					</tr>
																					</xsl:for-each>
																				</table>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Date Entry Format
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Default format for Date Entry Fields (Default: MM/DD/YYYY): </span>
																				<select name="DateEntryFormat" onchange="updateSaveButton()">
																					<option value="0">
																					<xsl:if test="root/customsettings/DateEntryFormat = '0'"><xsl:attribute name="selected">true</xsl:attribute></xsl:if>
																					MM/DD/YYYY</option>
																					<option value="1">
																					<xsl:if test="root/customsettings/DateEntryFormat = '1'"><xsl:attribute name="selected">true</xsl:attribute></xsl:if>
																					DD/MM/YYYY</option>
																				</select>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Left Menu Count Updates
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Left menu Ticket count update frequency (seconds)(Default:30) (0=Disabled): </span>
																				<input style="position:relative;left:17px;" name="UpdateFrequency" type="text" size="3" value="{root/customsettings/UpdateFrequency}" onkeydown="onTimeOutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	SMTP Host Name
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Host Name to use when issuing the SMTP HELO command (Default:ComputerName.Domain): </span>
																				<input style="position:relative;left:17px;" name="HeloHostName" type="text" size="45" maxlength="250" value="{root/customsettings/HeloHostName}" onkeydown="onTimeOutKeyDown();" />
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Date Display Time Zone
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Date Display Time Zone (Default:Use Server Operating System Time Zone): </span>
																				<select name="TimeZoneID" onchange="updateSaveButton()">
																					<option>
																						<xsl:attribute name="value">0</xsl:attribute>
																						<xsl:if test="/root/customsettings/TimeZoneID = '0'">
																						<xsl:attribute name="selected">true</xsl:attribute>
																						</xsl:if>
																						Use Server Operating System Time Zone																						
																					</option>
                                          <xsl:for-each select="/root/TimeZones/TimeZone">
                                            <option>
																							<xsl:attribute name="value"><xsl:value-of select="@ID"/></xsl:attribute>
																							<xsl:if test="/root/customsettings/TimeZoneID = @ID">
																							<xsl:attribute name="selected">true</xsl:attribute>
																							</xsl:if>
																							<xsl:value-of select="@DisplayName"/>																						
																						</option>
                                          </xsl:for-each>
                                        </select>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Maximum Threads
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Maximum ISAPI Extension Threads (5-128)(Default:5): </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:17px;" name="MaxISAPI" type="text" size="3" value="{root/customsettings/MaxISAPI}" onkeydown="onTimeOutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Request Queue Size (32-256)(Default:32): </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:17px;" name="QueueSize" type="text" size="3" maxlength="3" value="{root/customsettings/QueueSize}" onkeydown="onDBTimeoutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Number of Queued Requests before Application Pool Reloads (0-256) (Default:0=Disabled): </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:17px;" name="QueueFull" type="text" size="3" maxlength="3" value="{root/customsettings/QueueFull}" onkeydown="onDBTimeoutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Maximum Message Source Threads (Default:5): </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:17px;" name="MaxPOP3" type="text" size="3" value="{root/customsettings/MaxPOP3}" onkeydown="onTimeOutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Maximum Message Destination Threads (Default:5): </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:17px;" name="MaxSMTP" type="text" size="3" value="{root/customsettings/MaxSMTP}" onkeydown="onTimeOutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Agent Sessions
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Agent Sessions will Timeout after this many (minutes) of inactivity (Default:20) (0=Never): </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:17px;" name="SessionTimeout" type="text" size="3" value="{root/customsettings/SessionTimeout}" onkeydown="onTimeOutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Left Menu Ticket updates keep Sessions Alive: </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:15px;" id="chkKeepAlive" name="chkKeepAlive" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkKeepAlive = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Terminate all Sessions for Agent when Agent logs out: </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:15px;" id="chkLogoffAll" name="chkLogoffAll" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkLogoffAll = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Terminate all Sessions for Agent when one Agent Session times out: </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:15px;" id="chkExpireAll" name="chkExpireAll" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkExpireAll = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Allow Agents with Agent Delete Rights to Log Out other Agents: </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:15px;" id="chkAllowLogoff" name="chkAllowLogoff" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/chkAllowLogoff = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Save Agent Sessions to Database: </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:15px;" id="DbAgentSessions" name="DbAgentSessions" type="checkbox" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/DbAgentSessions = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Save Sessions to Database Frequency (seconds 30-60) (Default:60): </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:17px;" name="DBSessionFreq" type="text" size="2" maxlength="2" value="{root/customsettings/DBSessionFreq}" onkeydown="onDBTimeoutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Share Agent Sessions: </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:15px;" id="ShareAgentSessions" name="ShareAgentSessions" type="checkbox" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/ShareAgentSessions = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Session Sync Frequency (seconds 5-60) (Default:30): </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:17px;" name="SessionFreq" type="text" size="2" maxlength="2" value="{root/customsettings/SessionFreq}" onkeydown="onDBTimeoutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																		<tr>
																			<td nowrap="true" style="padding-right:5px;" valign="top">
																				<span>Agent Status Sync Frequency (seconds 5-60) (Default:30): </span>
																			</td>
																			<td width="100%" style="padding-right:5px;align:left;" valign="top">
																				<input style="position:relative;left:17px;" name="StatusFreq" type="text" size="2" maxlength="2" value="{root/customsettings/StatusFreq}" onkeydown="onDBTimeoutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
														</table>
													</td>
												</tr>
											</table>
										</td>
									</tr>	
								</table>
							</div>
							<div id="content6" style="overflow:auto;display:none;visibility:hidden;width:100%;height:100%;">
				  				<table style="width:100%;padding:10px;" border="0" cellspacing="0" cellpadding="0">
									<tr>
										<td>
											<table width="100%;" border="0" cellspacing="0" cellpadding="0">
												<tr>
													<td style="padding-right:10px;">
														<table cellspacing="0" border="0" width="100%">
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Contact Email Address Verification
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableVerification" name="chkEnableVerification" type="checkbox" onclick="onChkVerificationClick();updateSaveButton();">
																				<xsl:if test="/root/customsettings/enableVerification = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Enabled</span>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Settings
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Verify Contact Email Addresses every <input id="EmailVerifyDays" name="EmailVerifyDays" type="text" maxlength="4" size="3" value="{root/customsettings/EmailVerifyDays}" onkeydown="onTimeOutKeyDown();" onKeyPress="return(ValidateTextBox());"/> day(s) (Default:0=Never) </span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="EmailVerifyMx" name="EmailVerifyMx" type="checkbox" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/EmailVerifyMx = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Mark Status as Failed if no MX Record for Domain (Default:Yes)</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="EmailVerifyCatchAll" name="EmailVerifyCatchAll" type="checkbox" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/EmailVerifyCatchAll = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Add Domain to Bypass if Gateway (catch-all) Server detected (Default:Yes)</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Remove address from MyContacts and Contact Groups after <input id="EmailVerifyRemove" name="EmailVerifyRemove" type="text" maxlength="4" size="3" value="{root/customsettings/EmailVerifyRemove}" onkeydown="onTimeOutKeyDown();" onKeyPress="return(ValidateTextBox());"/> successive failures (Default:0=Never) </span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Delete address after <input id="EmailVerifyDelete" name="EmailVerifyDelete" type="text" maxlength="4" size="3" value="{root/customsettings/EmailVerifyDelete}" onkeydown="onTimeOutKeyDown();" onKeyPress="return(ValidateTextBox());"/> successive failures (Default:0=Never) </span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="EmailVerifyDecrement" name="EmailVerifyDecrement" type="checkbox" onclick="updateSaveButton();">
																				<xsl:if test="/root/customsettings/EmailVerifyDecrement = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Decrement failure count if address is used in Outbound Message (Default:Yes)</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Increment failure count by <input id="EmailVerifyIncrement" name="EmailVerifyIncrement" type="text" maxlength="4" size="3" value="{root/customsettings/EmailVerifyIncrement}" onkeydown="onTimeOutKeyDown();" onKeyPress="return(ValidateTextBox());"/> if address fails delivery (Default:2) </span>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	SMTP Session Timeout
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>SMTP Connection Timeout (seconds) (Default:10): </span>
																				<input style="position:relative;left:37px;" id="ConnectTimeout" name="ConnectTimeout" type="text" size="3" value="{root/customsettings/ConnectTimeout}" onkeydown="onDBTimeoutKeyDown();" onKeyPress="return(ValidateTextBox());"/>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Verification Bypass
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Do not perform Verification for:</span> <input id="btnAddBypass" name="btnAddBypass" type="button" class="childControlBtn" value="Add Item" onclick="addOption()"/>
																			</td>
																		</tr>
																		<tr>
			                                <td width="15%" style="padding-right:5px;padding-top:10px;" valign="top">
			                                  <input type="Hidden" name="BypassMaxID">
			                                    <xsl:attribute name="value">
			                                      <xsl:value-of select="root/customsettings/BypassMaxID"/>
			                                    </xsl:attribute>
			                                  </input>
			                                  <input type="Hidden" name="BypassIdCollection" value=""/>
			                                  <table  id="BypassTable">
			                                    <xsl:for-each select="root/Bypass/Item">
			                                      <xsl:variable name="BypassId" select="@ID"/>
			                                      <xsl:variable name="CurTypeId" select="@TypeID"/>
			                                      <tr id="{$BypassId}">
			                                        <td align="right">
			                                          <select onchange="updateSaveButton()">
			                                            <xsl:attribute name="name">BypassType<xsl:value-of select="$BypassId"/></xsl:attribute>
			                                            <xsl:attribute name="id">BypassType<xsl:value-of select="$BypassId"/></xsl:attribute>
			                                            <xsl:for-each select="/root/BypassTypes/BypassType">
			                                              <xsl:choose>
			                                                <xsl:when test="@ID = $CurTypeId">
			                                                  <option>
			                                                    <xsl:attribute name="value"><xsl:value-of select="@ID"/></xsl:attribute>
			                                                    <xsl:attribute name="selected">true</xsl:attribute>
			                                                    <xsl:value-of select="@Description"/>
			                                                  </option>
			                                                </xsl:when>
			                                                <xsl:otherwise>
			                                                  <option>
			                                                    <xsl:attribute name="value">
			                                                      <xsl:value-of select="@ID"/>
			                                                    </xsl:attribute>
			                                                    <xsl:value-of select="@Description"/>
			                                                  </option>
			                                                </xsl:otherwise>
			                                              </xsl:choose>
			                                            </xsl:for-each>
			                                          </select>
			                                        </td>
			                                        <td>
			                                          <input size="45" maxlength="250" type="text" onkeydown="onTimeOutKeyDown();">
			                                            <xsl:attribute name="name">Bypass<xsl:value-of select="$BypassId"/></xsl:attribute>
			                                            <xsl:attribute name="value"><xsl:value-of select="@Value"/></xsl:attribute>
			                                            <xsl:attribute name="id">Bypass<xsl:value-of select="$BypassId"/></xsl:attribute>
			                                          </input>
			                                        </td>
			                                        <td>
			                                          <input type="button" class="childControlBtn" rowIndex="0" value="Remove" onclick="delOption();">
			                                          	<xsl:attribute name="name">MatchDelButton</xsl:attribute>
			                                            <xsl:attribute name="id">MatchDelButton<xsl:value-of select="$BypassId"/></xsl:attribute>
			                                          </input>
			                                        </td>
			                                      </tr>
			                                    </xsl:for-each>
			                                  </table>
			                                  </td>
			                              </tr>
																	</table>
																</td>
															</tr>
														</table>
													</td>
												</tr>
											</table>
										</td>
									</tr>
								</table>
							</div>
							<div id="content7" style="overflow:auto;display:none;visibility:hidden;width:100%;height:100%;">
				  				<table style="width:100%;padding:10px;" border="0" cellspacing="0" cellpadding="0">
									<tr>
										<td>
											<table width="100%;" border="0" cellspacing="0" cellpadding="0">
												<tr>
													<td style="padding-right:10px;">
														<table cellspacing="0" border="0" width="100%">
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Ticket Tracking Bypass
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Do not add Ticket Tracking Data if any message recipient is:</span> <input id="btnAddTrackBypass" name="btnAddTrackBypass" type="button" class="childControlBtn" value="Add Item" onclick="addEmail()"/>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;padding-top:10px;" valign="top">
																				<input id="chkAgentEmailBypass" name="chkAgentEmailBypass" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/AgentEmailBypass = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Automatically include Agent Default Email Addresses in Bypass</span>
																			</td>
																		</tr>
																		<tr>
			                                <td width="15%" style="padding-right:5px;padding-top:10px;" valign="top">
			                                  <input type="Hidden" name="EmailMaxID">
			                                    <xsl:attribute name="value">
			                                      <xsl:value-of select="root/customsettings/EmailMaxID"/>
			                                    </xsl:attribute>
			                                  </input>
			                                  <input type="Hidden" name="EmailIdCollection" value=""/>
			                                  <table  id="EmailTable">
			                                    <xsl:for-each select="root/Email/Item">
			                                      <xsl:variable name="EmailId" select="@ID"/>
			                                      <xsl:variable name="CurTypeId" select="@TypeID"/>
			                                      <xsl:if test="$CurTypeId &lt; '2'">
			                                      <tr id="{$EmailId}">
			                                        <td align="right">
			                                          <select onchange="updateSaveButton()">
			                                            <xsl:attribute name="name">EmailType<xsl:value-of select="$EmailId"/></xsl:attribute>
			                                            <xsl:attribute name="id">EmailType<xsl:value-of select="$EmailId"/></xsl:attribute>
			                                            <xsl:for-each select="/root/EmailTypes/EmailType">
			                                              <xsl:choose>
			                                                <xsl:when test="@ID = $CurTypeId">
			                                                  <option>
			                                                    <xsl:attribute name="value"><xsl:value-of select="@ID"/></xsl:attribute>
			                                                    <xsl:attribute name="selected">true</xsl:attribute>
			                                                    <xsl:value-of select="@Description"/>
			                                                  </option>
			                                                </xsl:when>
			                                                <xsl:otherwise>
			                                                  <option>
			                                                    <xsl:attribute name="value">
			                                                      <xsl:value-of select="@ID"/>
			                                                    </xsl:attribute>
			                                                    <xsl:value-of select="@Description"/>
			                                                  </option>
			                                                </xsl:otherwise>
			                                              </xsl:choose>
			                                            </xsl:for-each>
			                                          </select>
			                                        </td>
			                                        <td>
			                                          <input size="45" maxlength="250" type="text" onkeydown="onTimeOutKeyDown();">
			                                            <xsl:attribute name="name">Email<xsl:value-of select="$EmailId"/></xsl:attribute>
			                                            <xsl:attribute name="value"><xsl:value-of select="@Value"/></xsl:attribute>
			                                            <xsl:attribute name="id">Email<xsl:value-of select="$EmailId"/></xsl:attribute>
			                                          </input>
			                                        </td>
			                                        <td>
			                                          <input type="button" class="childControlBtn" rowIndex="0" value="Remove" onclick="delEmail();">
			                                          	<xsl:attribute name="name">EmailDelButton</xsl:attribute>
			                                            <xsl:attribute name="id">EmailDelButton<xsl:value-of select="$EmailId"/></xsl:attribute>
			                                          </input>
			                                        </td>
			                                      </tr>
			                                      </xsl:if>
			                                    </xsl:for-each>
			                                  </table>
			                                  </td>
			                              </tr>
																	</table>
																</td>
															</tr>
														</table>
													</td>
												</tr>
											</table>
										</td>
									</tr>
								</table>
							</div>
							<div id="content8" style="overflow:auto;display:none;visibility:hidden;width:100%;height:100%;">
				  				<table style="width:100%;padding:10px;" border="0" cellspacing="0" cellpadding="0">
									<tr>
										<td>
											<table width="100%;" border="0" cellspacing="0" cellpadding="0">
												<tr>
													<td style="padding-right:10px;">
														<table cellspacing="0" border="0" width="100%">
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Auto Reply Bypass
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<span>Do not Auto Reply if email is from:</span> <input id="btnAddAutoBypass" name="btnAddAutoBypass" type="button" class="childControlBtn" value="Add Item" onclick="addAutoEmail()"/>
																			</td>
																		</tr>
																		<tr>
			                                <td width="15%" style="padding-right:5px;padding-top:10px;" valign="top">			                                  
			                                  <input type="Hidden" name="AutoEmailIdCollection" value=""/>
			                                  <table  id="AutoEmailTable">
			                                    <xsl:for-each select="root/Email/Item">
			                                      <xsl:variable name="EmailId" select="@ID"/>
			                                      <xsl:variable name="CurTypeId" select="@TypeID"/>
			                                      <xsl:if test="$CurTypeId = '2' or $CurTypeId = '3'">
			                                      <tr id="{$EmailId}">
			                                        <td align="right">
			                                          <select onchange="updateSaveButton()">
			                                            <xsl:attribute name="name">AutoEmailType<xsl:value-of select="$EmailId"/></xsl:attribute>
			                                            <xsl:attribute name="id">AutoEmailType<xsl:value-of select="$EmailId"/></xsl:attribute>
			                                            <xsl:for-each select="/root/AutoEmailTypes/EmailType">
			                                              <xsl:choose>
			                                                <xsl:when test="@ID = $CurTypeId">
			                                                  <option>
			                                                    <xsl:attribute name="value"><xsl:value-of select="@ID"/></xsl:attribute>
			                                                    <xsl:attribute name="selected">true</xsl:attribute>
			                                                    <xsl:value-of select="@Description"/>
			                                                  </option>
			                                                </xsl:when>
			                                                <xsl:otherwise>
			                                                  <option>
			                                                    <xsl:attribute name="value">
			                                                      <xsl:value-of select="@ID"/>
			                                                    </xsl:attribute>
			                                                    <xsl:value-of select="@Description"/>
			                                                  </option>
			                                                </xsl:otherwise>
			                                              </xsl:choose>
			                                            </xsl:for-each>
			                                          </select>
			                                        </td>
			                                        <td>
			                                          <input size="45" maxlength="250" type="text" onkeydown="onTimeOutKeyDown();">
			                                            <xsl:attribute name="name">AutoEmail<xsl:value-of select="$EmailId"/></xsl:attribute>
			                                            <xsl:attribute name="value"><xsl:value-of select="@Value"/></xsl:attribute>
			                                            <xsl:attribute name="id">AutoEmail<xsl:value-of select="$EmailId"/></xsl:attribute>
			                                          </input>
			                                        </td>
			                                        <td>
			                                          <input type="button" class="childControlBtn" rowIndex="0" value="Remove" onclick="delAutoEmail();">
			                                          	<xsl:attribute name="name">AutoEmailDelButton</xsl:attribute>
			                                            <xsl:attribute name="id">AutoEmailDelButton<xsl:value-of select="$EmailId"/></xsl:attribute>
			                                          </input>
			                                        </td>
			                                      </tr>
			                                      </xsl:if>
			                                    </xsl:for-each>
			                                  </table>
			                                  </td>
			                              </tr>
																	</table>
																</td>
															</tr>
														</table>
													</td>
												</tr>
											</table>
										</td>
									</tr>
								</table>
							</div>
							</div>
						</td>
						</tr>
						</table>
						</td>
						</tr>
						</table>
						</div>
					</td>
				</tr>
			</table>
			<xsl:for-each select="root/AgentNames/Agent">
			<input type="hidden" name="hiAgentID" disabled="true" value="{@ID}"/>
			<input type="hidden" name="hiAgentName" disabled="true" value="{@Name}"/>
			</xsl:for-each>
			<xsl:for-each select="root/GroupNames/Group">
			<input type="hidden" name="hiGroupID" disabled="true" value="{@ID}"/>
			<input type="hidden" name="hiGroupName" disabled="true" value="{@Name}"/>
			</xsl:for-each>
			<xsl:for-each select="root/BypassTypes/BypassType">
        <input type="hidden" name="hiBName" disabled="true">
          <xsl:attribute name="value">
            <xsl:value-of select="@Description"/>
          </xsl:attribute>
        </input>
      </xsl:for-each>
      <xsl:for-each select="root/BypassTypes/BypassType">
        <input type="hidden" name="hiBId" disabled="true">
          <xsl:attribute name="value">
            <xsl:value-of select="@ID"/>
          </xsl:attribute>
        </input>
      </xsl:for-each>
      <xsl:for-each select="root/EmailTypes/EmailType">
        <input type="hidden" name="hiEName" disabled="true">
          <xsl:attribute name="value">
            <xsl:value-of select="@Description"/>
          </xsl:attribute>
        </input>
      </xsl:for-each>
      <xsl:for-each select="root/EmailTypes/EmailType">
        <input type="hidden" name="hiEId" disabled="true">
          <xsl:attribute name="value">
            <xsl:value-of select="@ID"/>
          </xsl:attribute>
        </input>
      </xsl:for-each>
      <xsl:for-each select="root/AutoEmailTypes/EmailType">
        <input type="hidden" name="hiAEName" disabled="true">
          <xsl:attribute name="value">
            <xsl:value-of select="@Description"/>
          </xsl:attribute>
        </input>
      </xsl:for-each>
      <xsl:for-each select="root/AutoEmailTypes/EmailType">
        <input type="hidden" name="hiAEId" disabled="true">
          <xsl:attribute name="value">
            <xsl:value-of select="@ID"/>
          </xsl:attribute>
        </input>
      </xsl:for-each>
		</form>
		<script type="text/javascript">
			document.frmCustomSettings.action.value = "none";
			onChkCuttoffDateClick();
			onChkAgentActivityClick();
			onChkVerificationClick();
		</script>
	</body>
</html>
</xsl:template>
</xsl:stylesheet>