<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
<xsl:output method="html" encoding="utf-8" doctype-public="-//W3C//DTD HTML 4.0 Transitional//EN"  />
<xsl:include href="interface_templates.ems"/>
<xsl:template match="/"> 

<html>
<head>
		<title>Custom Settings</title>
		<link rel="STYLESHEET" type="text/css" href="{root/user/stylesheetname}"></link>
		<link rel="STYLESHEET" type="text/css" href="./stylesheets/datepicker.css"></link>
		<script type="text/javascript" src="./javascript/global.jmf"></script>
		<xsl:choose>
		<xsl:when test="root/DOCUMENT/dateformat = '0'">
		<script language="javascript" src="./javascript/datepicker.jmf"></script>
		</xsl:when>
		<xsl:otherwise>
		<script language="javascript" src="./javascript/datepicker1.jmf"></script>
		</xsl:otherwise>
		</xsl:choose>
		<script type="text/javascript" src="./javascript/tabs.jmf"></script>
		<script type="text/javascript" src="./javascript/customsettings.jmf"></script>
		<script type="text/javascript">
			var objCreateTicklerDate = null;
			var nCurCutOff = <xsl:value-of select='/root/customsettings/usecufoffreaddate'/>;
			var bSaveEnable = 0;
			
			function updateSaveButton()
			{
				document.frmCustomSettings.action.value = "update";
				bSaveEnable = 1;
				glo_initMenuButtons();
			}
			function onDBTimeoutKeyDown()
			{
				updateSaveButton();
			}
			function onLockTimeKeyDown()
			{
				updateSaveButton();
			}
			function onTimeOutKeyDown()
			{
				updateSaveButton();
			}
			function on3cxVersionKeyDown()
			{
				updateSaveButton();
			}
			function onClientVersionKeyDown()
			{
				updateSaveButton();
			}function onButtonMouseDown(id)
			{
				document.getElementById(id).className = "HiLightInsetButton";
			}
			
			function onButtonMouseUp(id)
			{
				document.getElementById(id).className = "HiLightButton";
			}
			
			function onChkCuttoffDateClick()
			{
				var isChecked = (document.frmCustomSettings.chkCutoffDate.checked) ? 1 : 0;
				
				var fields = new Array();
				fields[fields.length] = objCreateTicklerDate._input;
				fields[fields.length] = objCreateTicklerDate._button;
				
				if(isChecked != 0)
					glo_disableForm(true, fields);
				else
					glo_disableForm(false, fields);
					
				var bFormClean = true;
				var isChecked = (document.frmCustomSettings.chkCutoffDate.checked) ? 1 : 0;
				
				if(nCurCutOff != isChecked)
					bFormClean = false;
				
				if(bFormClean != true)
					onDBTimeoutKeyDown();
			}
			function onChkAgentActivityClick()
			{
				var isChecked = (document.frmCustomSettings.chkEnableAgentActivity.checked) ? 1 : 0;
				
				var fields = new Array();
				fields[fields.length] = document.frmCustomSettings.chkEnableAgentAuth;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketDelete;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketCreate;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketMove;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketEscalate;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketReassign;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketRestore;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketOpen;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketClose;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketLinked;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketUnlinked;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketMessageAdd;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketMessageDelete;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketMessageRevoke;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketMessageRelease;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketMessageReturn;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketLinkCreated;
				fields[fields.length] = document.frmCustomSettings.chkEnableTicketLinkDeleted;
				
				if(isChecked != 0)
					glo_disableForm(true, fields);
				else
					glo_disableForm(false, fields);
			}
			function onChkVerificationClick()
			{
				var isChecked = (document.frmCustomSettings.chkEnableVerification.checked) ? 1 : 0;
				
				var fields = new Array();
				fields[fields.length] = document.frmCustomSettings.EmailVerifyDays;
				fields[fields.length] = document.frmCustomSettings.EmailVerifyMx;
				fields[fields.length] = document.frmCustomSettings.EmailVerifyCatchAll;
				fields[fields.length] = document.frmCustomSettings.EmailVerifyRemove;
				fields[fields.length] = document.frmCustomSettings.EmailVerifyDelete;
				fields[fields.length] = document.frmCustomSettings.EmailVerifyDecrement;
				fields[fields.length] = document.frmCustomSettings.EmailVerifyIncrement;
				fields[fields.length] = document.frmCustomSettings.ConnectTimeout;
				fields[fields.length] = document.frmCustomSettings.btnAddBypass;
				for (i = 0; i &lt; document.getElementById("BypassTable").rows.length; i++)
				{
					thisID = document.getElementById("BypassTable").rows[i].id;
					fields[fields.length] = eval('document.frmCustomSettings.Bypass'+thisID);
					fields[fields.length] = eval('document.frmCustomSettings.BypassType'+thisID);
					fields[fields.length] = eval('document.frmCustomSettings.MatchDelButton'+thisID);
				}
				
				if(isChecked != 0)
					glo_disableForm(true, fields);
				else
					glo_disableForm(false, fields);
			}
			function applyCTAS()
			{
				if(confirm("Are you sure you want to apply the System Default\nfor Close Ticket After Send to the selected Agent\nor Group?"))
				{
					document.frmCustomSettings.action.value = "ctas";
					var postResults = glo_buildFormPost('frmCustomSettings');
					var proceed = postResults[0];
					if (proceed==true)
					{
						alert("Applied the default Close Ticket After Send setting to the selected Agent or Group!");
					}
					else
					{
						alert("The default Close Ticket After Send setting was not applied to the selected Agent or Group!");
					}
				}
			}
			function applyRRTM()
			{
				if(confirm("Are you sure you want to apply the System Default\nfor Route Replies To Me to the selected Agent or\nGroup?"))
				{
					document.frmCustomSettings.action.value = "rrtm";
					var postResults = glo_buildFormPost('frmCustomSettings');
					var proceed = postResults[0];
					if (proceed==true)
					{
						alert("Applied the default Route Replies To Me setting to the selected Agent or Group!");
					}
					else
					{
						alert("The default Route Replies To Me setting was not applied to the selected Agent or Group!");
					}
				}
			}
			function setWidth()
			{
				<xsl:if test="/root/DOCUMENT/useragent = 'Safari'">
					document.getElementById("tabHolderTable").width = window.innerWidth;
				</xsl:if>
				if ( this.parent.parent.theMainContain )
				{
				     this.parent.parent.docSetLoading(true);
				}						
			}
			window.onload=function(){tabInit();setWidth();adjustDoc();glo_initMenuButtons();};
			window.onresize=function(event){setWidth();};
		</script>
	</head>
	<body>
		<form name="frmCustomSettings" method="post" action="">
			<input name="action" type="hidden"/>
			<input name="3cxclientversion" type="hidden" value="0.0.0"/>
			<input name="mailflowclientversion" type="hidden" value="0.0.0"/>
			<input name="ooExcIDtoDel" type="hidden" value="0"/>
			<table id="docMasterTable" style="table-layout:fixed;height:100%;width:100%;" border="0" cellpadding="0" cellspacing="0">
				<tr>
					<td style="height:32px" class="menubarx" nowrap="true">
						<table style="height:100%" align="left" border="0" cellpadding="0" cellspacing="0">
							<tr>
								<td height="100%">
									<div class="toolBar" id="toolButton" name="toolButton" 
									 xrequire="bSaveEnable"  
									 title="Save Settings" onclick="onSaveClick()"
									  >
										<nobr>
											<img src="images/ico_save.gif" width="24" height="22" border="0"/>
											Save
										</nobr>
									  </div>
								</td>
								<td height="100%">					
									<div class="toolBar" id="toolButton" name="toolButton" 
									 xrequire="true"  
									 title="Show Help" onclick="openHelp('Administration/general_configuration/settings.htm')"
									  >
										<nobr>
											<img src="images/ico_help.gif" width="24" height="22" border="0"/>
											Help
										</nobr>
									  </div>
								</td>
							</tr>
						</table>
					</td>
				</tr>
				<tr>
					<td style="height:100%;width:100%;overflow:hidden;vertical-align:top;">
						<div style="width:100%;height:100%;overflow:auto">		
						<table id="tabHolderTable" style="table-layout:fixed;height:100%;" border="0" cellpadding="0" cellspacing="0" width="100%">
						<tr>
							<td id="tab_holder" style="height:24px;">
								<div id="tabs" style="position:relative!important;top:8px!important;width:100%;">
								<span id="tab1" useContent="true">
								<xsl:attribute name="class">
									<xsl:choose>
									<xsl:when test="root/DOCUMENT/URLPARAMETERS/TAB = 'tab1'">tabActive</xsl:when>
									<xsl:when test="not(root/DOCUMENT/URLPARAMETERS/TAB)">tabActive</xsl:when>
									<xsl:otherwise>tab</xsl:otherwise>
									</xsl:choose>
								</xsl:attribute>
								Agent Audit
								</span>
								<span id="tab2" useContent="true">
								<xsl:attribute name="class">
									<xsl:choose>
									<xsl:when test="root/DOCUMENT/URLPARAMETERS/TAB = 'tab2'">tabActive</xsl:when>
									<xsl:otherwise>tab</xsl:otherwise>
									</xsl:choose>
								</xsl:attribute>
								Office Hours
								</span>
								<span id="tab3" useContent="true">
								<xsl:attribute name="class">
									<xsl:choose>
									<xsl:when test="root/DOCUMENT/URLPARAMETERS/TAB = 'tab3'">tabActive</xsl:when>
									<xsl:otherwise>tab</xsl:otherwise>
									</xsl:choose>
								</xsl:attribute>
								Scheduled Reports
								</span>
								<span id="tab4" useContent="true">
								<xsl:attribute name="class">
									<xsl:choose>
									<xsl:when test="root/DOCUMENT/URLPARAMETERS/TAB = 'tab4'">tabActive</xsl:when>
									<xsl:otherwise>tab</xsl:otherwise>
									</xsl:choose>
								</xsl:attribute>
								Ticket Settings
								</span>
								<span id="tab5" useContent="true">
								<xsl:attribute name="class">
									<xsl:choose>
									<xsl:when test="root/DOCUMENT/URLPARAMETERS/TAB = 'tab5'">tabActive</xsl:when>
									<xsl:otherwise>tab</xsl:otherwise>
									</xsl:choose>
								</xsl:attribute>
								System Defaults
								</span>
								<span id="tab6" useContent="true">
								<xsl:attribute name="class">
									<xsl:choose>
									<xsl:when test="root/DOCUMENT/URLPARAMETERS/TAB = 'tab6'">tabActive</xsl:when>
									<xsl:otherwise>tab</xsl:otherwise>
									</xsl:choose>
								</xsl:attribute>
								Email Verification
								</span>
								<span id="tab7" useContent="true">
								<xsl:attribute name="class">
									<xsl:choose>
									<xsl:when test="root/DOCUMENT/URLPARAMETERS/TAB = 'tab7'">tabActive</xsl:when>
									<xsl:otherwise>tab</xsl:otherwise>
									</xsl:choose>
								</xsl:attribute>
								Tracking Bypass
								</span>
								<span id="tab8" useContent="true">
								<xsl:attribute name="class">
									<xsl:choose>
									<xsl:when test="root/DOCUMENT/URLPARAMETERS/TAB = 'tab8'">tabActive</xsl:when>
									<xsl:otherwise>tab</xsl:otherwise>
									</xsl:choose>
								</xsl:attribute>
								Auto Reply Bypass
								</span>	
							</div>
							</td>
						</tr>
						<tr>
						<td id="tab_canvas" class="tabActiveColor" style="height:100%;border-style:outset;border-width:1px;padding:10px;overflow:hidden;">
						<table style="table-layout:fixed;height:100%;width:100%;" border="0" cellpadding="0" cellspacing="0">
						<tr>
						<td style="height:100%;border-style:inset;border-width:1px;overflow:hidden;">
							<div style="width:100%;height:100%;overflow-y:auto;overflow-x:hidden;padding-right:10px;">		
								<div id="content1" style="overflow:auto;display:none;visibility:hidden;width:100%;height:100%;">
				  				<table style="width:100%;height:100%;padding:10px;" border="0" cellspacing="0" cellpadding="0">
									<tr>
										<td style="vertical-align:top;">
											<table width="100%;" border="0" cellspacing="0" cellpadding="0">
												<tr>
													<td style="padding-right:10px;">
														<table cellspacing="0" border="0" width="100%">
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Agent Audit
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableAgentActivity" name="chkEnableAgentActivity" type="checkbox" onclick="onChkAgentActivityClick();updateSaveButton();">
																				<xsl:if test="/root/customsettings/enableAgentActivity = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Enabled</span>
																			</td>
																		</tr>
																	</table>
																</td>
															</tr>
															<tr>
																<td width="100%" colspan="2" class="subSectionHeader" align="left">
																	Actions to Audit
																</td>
															</tr>
															<tr>
																<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																	<table width="100%" cellpadding="0" cellspacing="0">
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableAgentAuth" name="chkEnableAgentAuth" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableAgentAuth = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Login &amp; Logout</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketDelete" name="chkEnableTicketDelete" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketDelete = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Delete</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketCreate" name="chkEnableTicketCreate" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketCreate = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Create</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketMove" name="chkEnableTicketMove" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketMove = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Move</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketEscalate" name="chkEnableTicketEscalate" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketEscalate = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Escalate</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketReassign" name="chkEnableTicketReassign" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketReassign = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Reassign</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketRestore" name="chkEnableTicketRestore" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketRestore = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Restore</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketOpen" name="chkEnableTicketOpen" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketOpen = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Open</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketClose" name="chkEnableTicketClose" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketClose = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Close</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketLinked" name="chkEnableTicketLinked" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketLinked = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Linked</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketUnlinked" name="chkEnableTicketUnlinked" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketUnlinked = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Unlinked</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketMessageAdd" name="chkEnableTicketMessageAdd" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketMessageAdd = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Message Add</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketMessageDelete" name="chkEnableTicketMessageDelete" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketMessageDelete = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Message Delete</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketMessageRevoke" name="chkEnableTicketMessageRevoke" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketMessageRevoke = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Message Revoke</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketMessageRelease" name="chkEnableTicketMessageRelease" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketMessageRelease = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Message Release</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketMessageReturn" name="chkEnableTicketMessageReturn" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketMessageReturn = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Message Return</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketLinkCreated" name="chkEnableTicketLinkCreated" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketLinkCreated = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Link Created</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketLinkDeleted" name="chkEnableTicketLinkDeleted" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketLinkDeleted = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Ticket Link Deleted</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketChangeCategory" name="chkEnableTicketChangeCategory" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketChangeCategory = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
																				<span>Change TicketCategory</span>
																			</td>
																		</tr>
																		<tr>
																			<td width="15%" style="padding-right:5px;" valign="top">
																				<input id="chkEnableTicketChangeField" name="chkEnableTicketChangeField" type="checkbox" onclick="updateSaveButton();">
																					<xsl:if test="/root/customsettings/enableTicketChangeField = '1'"><xsl:attribute name="checked">checked</xsl:attribute></xsl:if>
																				</input>
