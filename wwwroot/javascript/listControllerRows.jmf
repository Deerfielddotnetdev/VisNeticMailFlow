function AreTicketsAlreadySelected()
{
	var listRow = getListRows();
	if(typeof listRow != "undefined")
	{
		for(var i = 0; i < listRow.length; i++)
		{
			if(listRow[i].className == trowOnClass || listRow[i].className == trowOnClassUnread)
				return 1;
		}
	}
	
	return 0;
}