var rcmen = null;
var rcmenIsShown = false;
var rcmen2 = null;
var rcmenIsShown2 = false;
var rcmen3 = null;
var rcmenIsShown3 = false;
var rcmen4 = null;
var rcmenIsShown4 = false;
var rcmen5 = null;
var rcmenIsShown5 = false;
var rcmen6 = null;
var rcmenIsShown6 = false;
var rcMenu="";
var preitem="";
var rcMenu2="";
var preitem2="";
var rcMenu3="";
var preitem3="";
var rcMenu4="";
var preitem4="";
var rcMenu5="";
var preitem5="";
var rcMenu6="";
var preitem6="";

function init()
{
	rcmen = null;
	var docName = getDocumentName(document.location);
	var selectId = document.tabularForm.selectId.value;
	if (selectId.length != 0)
	{
		if(docName == "sentitems.ems")
		{
			menh=198;	
		}
		if(docName == "outbox.ems")
		{
			menh=198;	
		}
		if(docName == "drafts.ems")
		{
			menh=162;
		}
		if(docName == "ticketlist.ems" || docName == "ticketsearchresults.ems" || docName == "contacthistory.ems")
		{
			menh=260;
		}
		if(docName == "mytickets.ems")
		{
			menh=198;
		}
		if(docName == "alertlist.ems")
		{
			menh=126;
		}
		if(docName == "client.ems")
		{
			menh=126;
		}
		menw=rcMenu_width;
		var winBottom = parent.document.getElementById("rightpane").offsetHeight;
		if ( glo_whichBrowser() == "Internet Explorer" )
		{
			menx=event.screenX;
			meny=event.screenY;			
		}
		else
		{
			menx=event.clientX;
			meny=event.clientY;
			if((meny+menh)>winBottom)
			{
				meny = winBottom-menh-20;
			}
		}
		
		if (window.createPopup)
	 	{       
    	if (!rcmen)
    	{
	      rcmen=window.createPopup();
				rcmen.document.write(rcMenu);
	    }
    	rcmen.show(menx,meny,menw,menh);
  	}
  	else
  	{
	    removeRcmen();
	    rcmen = document.createElement("div");
      rcmen.style.position = "absolute";
      rcmen.style.width = "260px";	        
      rcmen.style.top = meny;
      rcmen.style.left = menx;
      rcmen.id = "rcmen";
      var theMenu = rcMenu + "</div>";	        
      rcmen.innerHTML = theMenu;
      document.body.appendChild (rcmen);
      window.addEventListener ('click', removeRcmen, true);
      rcmenIsShown = true;              
      event.stopPropagation ();
	      
    }
		return false;
	}
	else
	{
		alert("You must select at least one item!");
		return false;
	}
}

function removeRcmen(event)
{
  if (rcmenIsShown)
  {
    document.body.removeChild(document.getElementById("rcmen"));  
    rcmenIsShown = false;
  }
  if (rcmenIsShown2)
  {
    document.body.removeChild(document.getElementById("rcmen2"));
    rcmenIsShown2 = false;
  }
  if (rcmenIsShown3)
  {
    document.body.removeChild(document.getElementById("rcmen3"));
    rcmenIsShown3 = false;
  }
  if (rcmenIsShown4)
  {
    document.body.removeChild(document.getElementById("rcmen4"));
    rcmenIsShown4 = false;
  }
  if (rcmenIsShown5)
  {
    document.body.removeChild(document.getElementById("rcmen5"));
    rcmenIsShown5 = false;
  }
  if (rcmenIsShown6)
  {
    document.body.removeChild(document.getElementById("rcmen6"));
    rcmenIsShown6 = false;
  }  
}

