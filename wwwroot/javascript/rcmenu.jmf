function rcMenu_item(txt,ico,lnk)
{
	if(txt == "hr")
	{
		preitem+=("<hr></hr>")
	}
	else
	{
		if(!ico)ico='./images/rc.gif';
		if ( glo_whichBrowser() == "Internet Explorer" )
		{
			preitem+=("<a href='#' onmousedown='parent.window.location.href=\""+lnk+"\"'><img src='"+ico+"' width='16' height='16' class='ico'> "+txt+"</a>")
		}
		else
		{
			preitem+=("<a href='#' onmousedown='window.location.href=\""+lnk+"\"'><img src='"+ico+"' width='16' height='16'> "+txt+"</a><br/>")
		}	
	}
}

