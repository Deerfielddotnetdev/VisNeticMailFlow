			var newTicketBoxView = reXML.selectSingleNode("/root/TicketBoxView/@ID").value;
			var newTicketId = reXML.selectSingleNode("/root/DestTicket/@ID").value;
			var newLoc = newPage+"?ticketboxview="+newTicketBoxView+"&ticket="+newTicketId;
			parent.frames.rightpane.location = newLoc;
			var newLink = (newPageId==1)?"nobrInbox":"nobrTicketsView"+newTicketBoxView;
			parent.frames.menu.UpdateNonAdminLink(newLink);
		} 			
	}
}

function viewMsg(type,msgObj)
{
	if(isNaN(parseInt(treeForm.selectId.value)) != true)
	{
		msgType = (msgObj.inbound == '1') ? 'inbound' : 'outbound';
		
		if(sFileName == 'ticketsearchresults.ems')
			qString = 'msg=' + msgObj.messageId + '&type=' + msgType + '&ticketboxview=' + ticketboxview + '&tsresult=1';
		else
			qString = 'msg=' + msgObj.messageId + '&type=' + msgType + '&ticketboxview=' + ticketboxview;
			
		if (type == 'preview' && usePreview == 1)
		{								
			opensplit('./vmsgframe.ems?file=viewmsg.ems&' +qString);
		}
		else
		{
			glo_launchViewMessage(qString);
		}

	}
}

function getSelectID(event)
{
	var selectId = document.tabularForm.selectId.value;
	if(!selectId)
	{
		gloListControl.listRowClick(event);
		selectId = document.tabularForm.selectId.value;
	}
	return selectId;
}

function viewTicket(selectId)
{
	if(selectId == "" || typeof selectId == "undefined")
	{
		selectId = document.tabularForm.selectId.value;
	}
	
	if(selectId == "")
	{
		alert("Please select a ticket");
	}
	else
	{
		if(window.dialogArguments != null)
		{
			var callerWindowObj = dialogArguments;
			callerWindowObj.parent.frames[0].glo_launchNewWindow("mailflow.ems?rightpane=ticketsearchresults.ems$action=search$hideleft=1$ticketid="+selectId+"$MAXLINES=100$nocancel=1");
		}
		else
		{
			glo_launchNewWindow("mailflow.ems?rightpane=ticketsearchresults.ems$action=search$hideleft=1$ticketid="+selectId+"$MAXLINES=100$nocancel=1");}
	}	
}
function updateInboundMsgAsRead(msgID, beenRead)
{
	var getURL = "/updateinbound.ems?OutputXML=1&msgID=" + msgID + "&beenRead=" + beenRead;

	//alert(getURL);

	try
	{
		xmlhttp.open('GET', getURL, false);
		if(xmlhttp.overrideMimeType){ xmlhttp.overrideMimeType('text/xml'); }
		xmlhttp.send();

		//alert("XMLHTTP Request Sent\n\nWith this alert there will be three requests to the ISAPI extension\nwithout this alert two requests are seen by the ISAPI extension");
		
		if (xmlhttp.responseXML && xmlhttp.responseXML.xml && xmlhttp.status == 200) 
		{
			return 1;
		}
	}
	catch(e) 
	{
		alert("An error occurred connecting to the server.\nThe server is either offline, or you have been disconnected from the Internet.");	
	}
	
	return 0;	
}

function updateNoteAsRead(noteID, beenRead)
{
	var getURL = "/updateticketnotes.ems?OutputXML=1&selectid=" + noteID + "&beenRead=" + beenRead;

	try
	{
		xmlhttp.open('GET', getURL, false);
		if(xmlhttp.overrideMimeType){ xmlhttp.overrideMimeType('text/xml'); }
		xmlhttp.send();

		//alert("XMLHTTP Request Sent\n\nWith this alert there will be three requests to the ISAPI extension\nwithout this alert two requests are seen by the ISAPI extension");
		
		if (xmlhttp.responseXML && xmlhttp.responseXML.xml && xmlhttp.status == 200) 
		{
			return 1;
		}
	}
	catch(e) 
	{
		alert("An error occurred connecting to the server.\nThe server is either offline, or you have been disconnected from the Internet.");	
	}
	
	return 0;	
}
	
function hdlTreeClick(objcol)
{
	if (objcol.length)
	{
		for(i = 0; i < objcol.length; i++)
		{
			if(objcol[i].getAttribute('selected') == 'true')
			{
				obj = objcol[i];break;
			}
		}
	}
	else
	{
		obj = objcol;
	}
	
	//if(obj.parentNode)
		//obj.parentNode.style.fontWeight = "normal";
	
	if(obj.id.indexOf('notes') != -1 && obj.id.indexOf('sys') == -1)
	{
		// tree type is a note
		ticketDim = obj.getAttribute('ticketDim');
		var ticketNoteID = document.treeForm.selectId.value;
		url = './ticketNotes.ems?selectId=' + document.treeForm.selectId.value;// +'&amp;TicketID='+obj.getAttribute('ticketId');
		
		if(document.getElementById('threadTree' + obj.getAttribute('ticketId')))
		{
			if(glo_whichBrowser()=='Firefox')
			{
				var threadTree = 'threadTree' + obj.getAttribute('ticketId');
				var theDivs = glo_elementsById(threadTree);
				clearTree(theDivs);
			}
			else
			{
				var threadTree = eval('threadTree' + obj.getAttribute('ticketId'));
				clearTree(threadTree);
			}
		}
		
		if(document.getElementById('sequenceTree' + obj.getAttribute('ticketId')))
		{
			if(glo_whichBrowser()=='Firefox')
			{
				var seqTree = 'sequenceTree' + obj.getAttribute('ticketId');
				var theDivs = glo_elementsById(seqTree);
				clearTree(theDivs);
			}
			else
			{
				var seqTree = eval('sequenceTree'+obj.getAttribute('ticketId'));
				clearTree(seqTree);
			}
		}
		
		var ticketObj = Tickets[ticketDim];
		var nUnReadCount = 0;	// Total unread notes in ticket
		
		// Verify we have a valid Ticket Object
		//var bUpdated = false;
		if(ticketObj)
		{
			for(var j = 0; j < ticketObj.notes.length; j++)
			{
				if(ticketObj.notes[j].beenread == 0)
					nUnReadCount++;
			}
				
			if(nUnReadCount > 0)
			{
				gloListControl.updateHasReadNotes(ticketObj.rowId, ticketObj.notecount, nUnReadCount);
			}
			else
			{
				gloListControl.updateHasReadNotes(ticketObj.rowId, ticketObj.notecount);
				parent.frames.menu.updateTicketCount();
			}		
		}
		
		if(usePreview == 1)
		{
			opensplit(url); 
		}
		else
		{
			closesplit();
			glo_launchModalWindow('./modalframe.ems?file=' + url, 600, 400, 'yes', 'no', 'no');
		}
	}
	else if (obj.id.indexOf('sys') != -1)
	{
		// tree type is sys note
		msgid = obj.getAttribute('msgid');
		inbound = obj.getAttribute('inbound');
		archiveid = obj.getAttribute('archiveid');
		
		url = '/vmsgframe.ems?file=viewmsg.ems&archiveid=' + archiveid +'&msg='+msgid+'&type='+inbound;
		if(usePreview == 1) {
			opensplit(url); 
		}else{
			closesplit();
			glo_launchModalWindow('./modalframe.ems?file=' + url, 600, 400, 'yes', 'no', 'no');
		}				
	}
	else
	{	
		// tree type is a message
		ticketDim = obj.getAttribute('ticketDim') ? obj.getAttribute('ticketDim') : obj.ticketDim;
		msgDim = obj.getAttribute('msgDim') ? obj.getAttribute('msgDim') : obj.msgDim;
		type = obj.getAttribute('type') ? obj.getAttribute('type') : obj.type;
		
		notesTree = 'notesTree' + Tickets[ticketDim].ticketid;
		threadTree = 'threadTree' + Tickets[ticketDim].ticketid;
		seqTree = 'sequenceTree' + Tickets[ticketDim].ticketid;
		
		if(document.getElementById(notesTree))
		{
			var notesTree = eval(notesTree);
			clearTree(notesTree);
		}
		
		var nUnReadCount = 0;
		TicketObj = Tickets[ticketDim];
		
		if(type == 'threaded')
		{							
			for(var i = 0; i < TicketObj.threadedMsg.length; i++)
			{
				MsgObj = TicketObj.threadedMsg[i];
				if(MsgObj.beenread == 0)
					nUnReadCount++;
			}
			
			if(document.getElementById(seqTree))
			{
				var seqTree = eval(seqTree);
				clearTree(seqTree);
			}
			
			MsgObj = Tickets[ticketDim].threadedMsg[msgDim];
			
		}
		else
		{				
			MsgObj = Tickets[ticketDim].sequenceMsg[msgDim];
			
			
			for(var i = 0; i < TicketObj.sequenceMsg.length; i++)
			{
				MsgObj = TicketObj.sequenceMsg[i];
				if(MsgObj.beenread == 0)
					nUnReadCount++;
			}
			
			if(document.getElementById(threadTree))
			{
				var threadTree = eval(threadTree);
				clearTree(threadTree);
			}
			
			MsgObj = Tickets[ticketDim].sequenceMsg[msgDim];					
		}
		
		Tickets[ticketDim].setSelection(MsgObj);
		
		if(nUnReadCount > 0)
			gloListControl.updateHasRead(TicketObj.rowId, TicketObj.msgcount, nUnReadCount);
		else
			gloListControl.updateHasRead(TicketObj.rowId, TicketObj.msgcount);
		
		if(usePreview == 1)
			viewMsg('preview',MsgObj);
	}	

}

function hdlTreeDblClick(objcol) {
	var obj = null;
	if ( objcol.length )
	{
		for(i = 0; i < objcol.length; i++)
		{
			if(objcol[i].getAttribute('selected') == 'true')
			{
				obj = objcol[i];
				break;
			}
		}
	}
	else
	{
		obj = objcol;
		if(!obj.id)
		{
			obj = objcol.msgRow;
		}
	}
	
	if(obj.id.indexOf('notes') != -1 && obj.id.indexOf('sys') == -1) {
		// tree type is a ticket
		url = 'ticketNotes.ems&selectId=' + document.treeForm.selectId.value;// +'&amp;TicketID='+obj.getAttribute('ticketId');
		closesplit();
		glo_launchModalWindow('./modalframe.ems?file=' + url, 600, 400, 'yes', 'no', 'no');
	
	} else if (obj.id.indexOf('sys') != -1){
		// tree type is sys note
		msgid = obj.getAttribute('msgid');
		inbound = obj.getAttribute('inbound');
		archiveid = obj.getAttribute('archiveid');
		
		url = 'archiveid=' + archiveid +'&msg='+msgid+'&type='+inbound;
		glo_launchViewMessage(url);
		
	} else {
		ticketDim = obj.getAttribute('ticketDim') ? obj.getAttribute('ticketDim') : obj.ticketDim;
		msgDim = obj.getAttribute('msgDim') ? obj.getAttribute('msgDim') : obj.msgDim;
		type = obj.getAttribute('type') ? obj.getAttribute('type') : obj.type;
		
		if(type == 'threaded') {
			targetObj = Tickets[ticketDim].threadedMsg[msgDim];
		} else {
			targetObj = Tickets[ticketDim].sequenceMsg[msgDim];
		}
		viewMsg('newwin',targetObj);
	}
}
	
function viewFunc(func)
{
	if (func == 'owned')
	{
		var newVal = (parseInt(document.tabularForm.ShowOwnedItems.value) == 1) ? 0 : 1;
		
		var newUrl = new String("./"+docName+"?TicketBoxView="+ticketboxview+"&CurrentPage="+currentpage);
		newUrl = newUrl + "&ShowOwnedItems="+newVal;
		document.location = newUrl;
		parent.frames.menu.updateTicketCount();
	}
	if (func == 'closed')
	{
		var newVal = (parseInt(document.tabularForm.ShowClosedItems.value) == 1) ? 0 : 1;
		
		var newUrl = "";
		
		if(usecustomview != 0)
		{
			newUrl = new String("./"+docName+"?CustomTicketBoxView="+usecustomview+"&CurrentPage="+currentpage+"&AgentID="+customagentid);
			newUrl = newUrl + "&ShowClosedItems="+newVal;
		}
		else
		{
			newUrl = new String("./"+docName+"?TicketBoxView="+ticketboxview+"&CurrentPage="+currentpage);
			newUrl = newUrl + "&ShowClosedItems="+newVal;
		}
		
		document.location = newUrl;
		parent.frames.menu.updateTicketCount();
	}
}

