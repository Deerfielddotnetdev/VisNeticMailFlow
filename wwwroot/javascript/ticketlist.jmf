			var newTicketBoxView = reXML.selectSingleNode("/root/TicketBoxView/@ID").value;
			var newTicketId = reXML.selectSingleNode("/root/DestTicket/@ID").value;
			var newLoc = newPage+"?ticketboxview="+newTicketBoxView+"&ticket="+newTicketId;
			parent.frames.rightpane.location = newLoc;
			var newLink = (newPageId==1)?"nobrInbox":"nobrTicketsView"+newTicketBoxView;
			parent.frames.menu.UpdateNonAdminLink(newLink);
		} 			
	}
}

