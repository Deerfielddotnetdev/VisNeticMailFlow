function linkTicketAction(doWhat,linkName)
{
	var selectId = document.tabularForm.selectId.value;
	if(doWhat == "linkTickets")
	{
		var thisUrl = "changeticket.ems?postXML=1&LinkId="+selectId+"&linkName="+linkName+"&ChangeTicketBoxView="+ticketboxview+"&Action=linkTickets";
		var useThisForm = new Array();
		var postResults = glo_buildFormPost('tabularForm', thisUrl, null, useThisForm);
		if (postResults[0]==true)
		{
			var reXML = postResults[2];
			var newPageId = reXML.selectSingleNode("/root/TicketBoxView/@TYPE").value;
			if(newPageId == 0)
			{
				parent.frames.rightpane.location = parent.frames.rightpane.location;
				parent.frames.menu.UpdateNonAdminLink('spanTicketSearch');
			}
			else
			{
				var newPage = (newPageId==1)?"mytickets.ems":"ticketlist.ems";
				var newTicketBoxView = reXML.selectSingleNode("/root/TicketBoxView/@ID").value;
				var newTicketId = reXML.selectSingleNode("/root/DestTicket/@ID").value;
				var newLoc = newPage+"?ticketboxview="+newTicketBoxView+"&ticket="+newTicketId;
				parent.frames.rightpane.location = newLoc;
				var newLink = (newPageId==1)?"nobrInbox":"nobrTicketsView"+newTicketBoxView;
				parent.frames.menu.UpdateNonAdminLink(newLink);
			}
		}
	}
	else if(doWhat == "linkTicketsTicket")
	{
		parent.frames.rightpane.location = 'ticketsearch.ems?linkName='+linkName+'&linkTbView='+ticketboxview+'&LinkID='+selectId;
		parent.frames.menu.UpdateNonAdminLink('spanTicketSearch');
	}
	else if(doWhat == "linkTicketsLink")
	{
		parent.frames.rightpane.location = 'ticketlinks.ems?Action=addtolink&ChangeTicketBoxView='+ticketboxview+'&srcticketID='+selectId;
		parent.frames.menu.UpdateNonAdminLink('spanTicketLinks');
	}
	else if(doWhat == "delTicketFromLink")
	{
		var selectIdArr = selectId.split(",");
		var usrResponse = null;
		if (selectIdArr.length > 1)
		{
			usrResponse = confirm('Are you sure you want to remove these tickets from this Ticket Link?\n\nIf one or fewer Tickets remain in the Ticket Link the Link will be deleted.');
		}
		else
		{
			usrResponse = confirm('Are you sure you want to remove this ticket from this Ticket Link?\n\nIf one or fewer Tickets remain in the Ticket Link the Link will be deleted.');
		}
		if (usrResponse)
		{
			var thisUrl = "changeticket.ems?postXML=1&TicketID="+selectId+"&LinkID="+changeTicketLinkId+"&Action=delTickets";
			var useThisForm = new Array();
			var postResults = glo_buildFormPost('tabularForm', thisUrl, null, useThisForm);
			if (postResults[0]==true)
			{
				var newLoc = "ticketsearchresults.ems?nocancel=1&Action=search&hideleft=1&ticketlink=2&ticketlinkid=" + changeTicketLinkId
				document.location = newLoc;
				parent.frames.menu.UpdateNonAdminLink('spanTicketSearch');
			}
		} 
	}
}

