function createTickets()
{
	// creates the list of tickets, etc
	Tickets.length = 0;
	var arr = new Array(); 
  arr = document.getElementsByName("TicketObject");		
	if (arr.length)
	{
		for(toDim=0; toDim < arr.length; toDim++)
		{
			thisId = Tickets.length;
			Tickets[thisId] = new Ticket(thisId);
			Tickets[thisId].init();
		}
		glo_decodeListCell();
	}
	else if (document.TicketObject)
	{
		// one ticket
		Tickets[0] = new Ticket(0);
		Tickets[0].init();
		glo_decodeListCell();
	}
	else
	{
		// no tickets!
	}
	try
	{
		document.getElementById("numTickets").innerHTML = "Number Tickets: <b>" + Tickets.length + "</b>";
	}
	catch(e){}
}

function toggleElm() {
	// used to toggle the message area on and off.
	
	img = window.event.srcElement;
	container = window.event.srcElement.parentElement;
	currentView = Tickets[container.getAttribute('ticketDim')].currentView;
	
	if (currentView == 'threaded') {
		msg = Tickets[container.getAttribute('ticketDim')].threadedMsg[container.msgDim];
	} else {
		msg = Tickets[container.getAttribute('ticketDim')].sequenceMsg[container.msgDim];
	}

	for (i = 0; i < msg.objChildren.length; i++) {
		if(msg.objChildren[i].msgContainer.style.display == 'none') {
			msg.objChildren[i].msgContainer.style.display = 'block';
			img.src = contractico.src;
		} else {
			msg.objChildren[i].msgContainer.style.display = 'none';
			img.src = expandico.src;
		}
	}
	event.cancelBubble = true;
}

function updateTicketAndMsgToRead(ticketID, nRead)
{	
	var ticketObj = null;  // Ticket Object variable to work with
	var nUnReadCount = 0;	// Total unread messages in ticket
	
	// Loop thru Tickets array and find the ticket object with
	// The ticket id we passed in
	for(var i = 0; i < Tickets.length; i++)
	{
		if(Tickets[i].ticketid == ticketID)
		{
			ticketObj = Tickets[i];
			break;
		}
	}
	
	// Verify we have a valid Ticket Object
	if(ticketObj)
	{
		var treeId = 'threadTree' + ticketID;		// id name of our threadMsg div
		var seqId = 'sequenceTree' + ticketID;		// id name of our sequenceMsg div
		
		var obj = document.getElementById(treeId);	// Our msg div object try threadMsg first
		
		// No threadMsg so try sequenceMsg
		if(obj == null)
			obj = document.getElementById(seqId);		
		
		// Neither one has been created
		if(obj != null)
		{
			var type = obj.getAttribute('type');	// Get type from our msg div
			
			var MsgObj = ticketObj.whatsSelected;
			
			MsgObj.beenread = nRead;
			
			updateInboundMsgAsRead(MsgObj.messageId, nRead);
			
			if(type == 'threaded')
			{
				for(var i = 0; i < TicketObj.threadedMsg.length; i++)
				{
					MsgObj = TicketObj.threadedMsg[i];
					if(MsgObj.beenread == 0)
						nUnReadCount++;
				}
			}
			else
			{
				for(var i = 0; i < ticketObj.sequenceMsg.length; i++)
				{
					MsgObj = ticketObj.sequenceMsg[i];
					if(MsgObj.beenread == 0)
						nUnReadCount++;
				}
			}
			
			MsgObj = ticketObj.whatsSelected;
			
			if(nRead)
				MsgObj.msgContainer.style.fontWeight = "normal";
			else
				MsgObj.msgContainer.style.fontWeight = "bold";
			
			if(nUnReadCount > 0)
			{
				gloListControl.updateHasRead(ticketObj.rowId, ticketObj.msgcount, nUnReadCount);
			}
			else
			{
				gloListControl.updateHasRead(ticketObj.rowId, ticketObj.msgcount);
				parent.frames.menu.updateTicketCount();
			}				
		}
		
	}
}

function updateTicketAndNoteToRead(ticketID, ticketNoteID, nRead)
{
var ticketObj = null;  // Ticket Object variable to work with
var nUnReadCount = 0;	// Total unread notes in ticket

for(var i = 0; i < Tickets.length; i++)
{
	if(Tickets[i].ticketid == ticketID)
	{
		ticketObj = Tickets[i];
		break;
	}
}
		
// Verify we have a valid Ticket Object
if(ticketObj)
{
	for(var j = 0; j < ticketObj.notes.length; j++)
	{
		if(ticketObj.notes[j].noteId == ticketNoteID)
		{
			ticketObj.notes[j].beenread = nRead;
			if(nRead)
				ticketObj.notes[j].NoteContainer.style.fontWeight = "normal";
			else
				ticketObj.notes[j].NoteContainer.style.fontWeight = "bold";
			updateNoteAsRead(ticketObj.notes[j].noteId, nRead);
		}
	}
	
	
	for(var k = 0; k < ticketObj.notes.length; k++)
	{
		if(ticketObj.notes[k].beenread == 0)
			nUnReadCount++;
	}
	
	if(nUnReadCount > 0)
	{
		gloListControl.updateHasReadNotes(ticketObj.rowId, ticketObj.notecount, nUnReadCount);
	}
	else
	{
		gloListControl.updateHasReadNotes(ticketObj.rowId, ticketObj.notecount);
		parent.frames.menu.updateTicketCount();
	}			
}
}

function updateTicketRead(ticketID, rowID, numMsgs, numNotes, nRead)
{	
	var getURL = "/ticketread.ems?ticketid=" + ticketID + "&action=" + nRead;

	try
	{
		xmlhttp.open('GET', getURL, false);
		if(xmlhttp.overrideMimeType){ xmlhttp.overrideMimeType('text/xml'); }
		xmlhttp.send();

		//alert("XMLHTTP Request Sent\n\nWith this alert there will be three requests to the ISAPI extension\nwithout this alert two requests are seen by the ISAPI extension");
		
		if (xmlhttp.responseXML && xmlhttp.responseXML.xml && xmlhttp.status == 200) 
		{
			return 1;
		}
	}
	catch(e) 
	{
		alert("An error occurred connecting to the server.\nThe server is either offline, or you have been disconnected from the Internet.");	
	}
	
	return 0;
}