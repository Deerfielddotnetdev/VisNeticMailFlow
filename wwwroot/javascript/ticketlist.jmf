function tSort(column,asc) 
{	

	if (!bResizedCols )
	{
		var newUrl = "";
		
		if(usecustomview != 0)
		{
			newUrl = new String("./"+docName+"?CustomTicketBoxView="+usecustomview+"&CurrentPage="+currentpage+"&AgentID="+customagentid);
			newUrl = newUrl + "&SortBy="+column+"&SortAscending="+((asc == 1)?0:1);
			newUrl = newUrl + "&Action=sort";
			
		}
		else
		{
			newUrl = new String("./"+docName+"?TicketBoxView="+ticketboxview+"&CurrentPage="+currentpage);
			newUrl = newUrl + "&SortBy="+column+"&SortAscending="+((asc == 1)?0:1);
			newUrl = newUrl + "&Action=sort";
		}
		glo_doReload('ListHolder',newUrl);
	}
	bResizedCols = false;
}

function getOldest(num)
{

	document.tabularForm.Action.value = "getoldest";
	document.tabularForm.selectId.value = num;
	var postResults = glo_buildFormPost('tabularForm');
	if (postResults[0]==true)
	{
		var reXML = postResults[2];			
		if (reXML.selectSingleNode("/root/UpdateAllCounts"))
		{
			// Have to..
			parent.frames.menu.updateTicketCount();
		}
		var newUrl = "./"+docName+"?TicketBoxView="+ticketboxview+"&CurrentPage="+currentpage;
		document.location = newUrl;
	} 
}

function conFunc(func,contact) {
	if (contact != '') {
		if (func == 'history') {
			glo_launchNewWindow("mailflow.ems?rightpane=contacthistory.ems$contactid="+contact);
			//document.location='contacthistory.ems?contactid='+contact+'&ticketboxview='+ticketboxview;
		}
		if (func == 'edit') {
			document.location='contact.ems?contact='+contact;	
		}
	}
}
function doChangeTicketModal(ID,Type,doWhat) {
	if(doWhat == 'new') {
		document.location = 'changeticket.ems?msgId='+ID+'&msgType='+Type+'&destTicketId=0&Action=change';
	} else if(doWhat == 'move') {
		document.location = 'ticketsearch.ems?msgID='+ID+'&msgtype='+Type;	
	}
	closesplit();
}
function doChangeTicket(showDest) {
	var selectId = document.tabularForm.selectId.value;
	if(selectId == ""){
		alert("Please select a destination ticket");
	} else {
		var thisUrl = "changeticket.ems?postXML=1&msgId="+changeTicketMsgId+"&msgType="+changeTicketMsgType+"&changeTicketBoxView="+changeTicketBoxView+"&changeTicketShowDest="+changeTicketShowDest+"&destTicketId="+selectId+"&Action=change";
		var useThisForm = new Array();
		var postResults = glo_buildFormPost('tabularForm', thisUrl, null, useThisForm);
		if (postResults[0]==true)
		{
			var reXML = postResults[2];
			var newPageId = reXML.selectSingleNode("/root/TicketBoxView/@TYPE").value;
			var newPage = (newPageId==1)?"mytickets.ems":"ticketlist.ems";
			var newTicketBoxView = reXML.selectSingleNode("/root/TicketBoxView/@ID").value;
			var newTicketId = reXML.selectSingleNode("/root/DestTicket/@ID").value;
			var newLoc = newPage+"?ticketboxview="+newTicketBoxView+"&ticket="+newTicketId;
			parent.frames.rightpane.location = newLoc;
			var newLink = (newPageId==1)?"nobrInbox":"nobrTicketsView"+newTicketBoxView;
			parent.frames.menu.UpdateNonAdminLink(newLink);
		} 			
	}
}
function takeOwnership()
{ 
	if(document.tabularForm.selectId.value != "")
	{
		document.tabularForm.Action.value = "takeownership";
		var postResults = glo_buildFormPost('tabularForm');
		if (postResults[0]==true)
		{
			var reXML = postResults[2];			
			if (reXML.selectSingleNode("/root/UpdateAllCounts"))
			{
				parent.frames.menu.updateTicketCount();
			}
			if(docName == "ticketsearchresults.ems")
			{
				glo_doReload('ListHolder',window.location.href);
			}
			else
			{
				var necUrls = glo_remUrlVar(document.location.search, "ticket=");
				if( necUrls != "" && necUrls != false)
				{
					necUrls = glo_remUrlVar(necUrls, "TicketBoxView=");
					if( necUrls != "" && necUrls != false)
					{
						necUrls = glo_remUrlVar(necUrls, "CurrentPage=");
					}
				}
				if( necUrls == false)
				{
					necUrls = "";
				}
				var newLoc = "./"+docName+"?TicketBoxView="+ticketboxview+"&CurrentPage="+currentpage+necUrls.replace("?","&");
				glo_doReload('ListHolder',newLoc);
			}
			
		} 
	}
}

