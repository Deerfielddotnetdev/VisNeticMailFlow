function listRowClick()
{	

	if (window.event.srcElement.getAttribute("glc_form_tabularForm_selectId") != null)
	{
		oEvent = window.event.srcElement;
	}
	else
	{
		oEvent = window.event.srcElement;
		while (oEvent.parentElement.tagName != "TABLE")
		{
			oEvent = oEvent.parentElement;
			if (oEvent.getAttribute("glc_form_tabularForm_selectId") != null)
			break;
		}
		oImg = oEvent.children[0].children[0].children[0];
		tabularForm.selectId.value = oEvent.glc_form_tabularForm_selectId;
		if(document.getElementById('messagearea' + tabularForm.selectId.value)) {
			oContainer = eval('messagearea' + tabularForm.selectId.value);
		} else {
			oContainer = null;
		}
		if (oImg.src.indexOf('./images/minus.gif') != -1) {
			
			oImg.src = expandico.src;
			if (oContainer != null) {
				oContainer.style.display = 'none';				
			}
			if (usePreview==1)closesplit();
		 } else {
			oImg.src = contractico.src;
			if (oContainer != null) {
				Tickets[oEvent.tabRowId].forceUpdate('messages');
				Tickets[oEvent.tabRowId].forceUpdate('notes');
				oContainer.style.display = 'block';
				Tickets[oEvent.tabRowId].selectSelection();	
				
			}
		}
	}		
	
	for (i = 0; i < Tickets.length; i++) {
		if(Tickets[i].ticketid != oEvent.glc_form_tabularForm_selectId) {
			msgContainer = eval('messagearea' + Tickets[i].ticketid);
			msgIndicator = eval('document.msgindicator' + Tickets[i].ticketid);
			if(msgContainer.style.display == 'block') {
				msgContainer.style.display = 'none';
				msgIndicator.src = expandico.src;
			}
		}
	}
	
}

/* form handlers */
function ticketFunc(doWhat)
{
	if(glo_isBtnDisabled()){return false;}		
	var selectId = window.document.tabularForm.selectId.value;
	var listRow = getListRows();			
	
	if (doWhat == 'new') {
		glo_launchMsgCompWindow(null, null, ticketboxview, ticketboxid, null, null, null);
	}
	if (doWhat == 'addtoticket') {
		glo_launchMsgCompWindow(null, null, ticketboxview, ticketboxid, selectId, null, null);
	}
	
	if (selectId.length != 0)
	{
		if (doWhat == 'delete')
		{
			var selectIdArr = selectId.split(",");
			var usrResponse = null;
			if (selectIdArr.length > 1)
				usrResponse = confirm('Are you sure you want to delete these tickets?');
			else
				usrResponse = confirm('Are you sure you want to delete this ticket?');
			if (usrResponse)
			{
				if (docName=="ticketsearchresults.ems" || docName=="contacthistory.ems")
				{
					document.tabularForm.Action.value = doWhat;
					var postResults = glo_buildFormPost('tabularForm');
					var reXML = postResults[2];			
					if (reXML.selectSingleNode("/root/UpdateAllCounts"))
					{
						parent.frames.menu.updateTicketCount();
					}
					glo_doReload('ListHolder',window.location.href);
				}
				else
				{
					document.tabularForm.Action.value = doWhat;
					var postResults = glo_buildFormPost('tabularForm');
					if (postResults[0]==true)
					{
						var reXML = postResults[2];			
						if (reXML.selectSingleNode("/root/UpdateAllCounts"))
						{
							parent.frames.menu.updateTicketCount();
						}
						
						var newUrl = "";
						if(docName == "mytickets.ems")
						{
							if(reXML.selectSingleNode("/root/TicketBoxItemList/@customviewid"))
							{
								var nCustomView = reXML.selectSingleNode("/root/TicketBoxItemList/@customviewid").value;
								if(nCustomView != 0)
									newUrl = "./"+docName+"?CustomTicketBoxView="+nCustomView+"&CurrentPage="+currentpage;
								else
									newUrl = "./"+docName+"?TicketBoxView="+ticketboxview+"&CurrentPage="+currentpage;
							}
							else
							{
								newUrl = "./"+docName+"?TicketBoxView="+ticketboxview+"&CurrentPage="+currentpage;
							}
						}	
						else
						{
							newUrl = "./"+docName+"?TicketBoxView="+ticketboxview+"&CurrentPage="+currentpage;
						}
						glo_doReload('ListHolder',newUrl);
					}
				}
			}
		}
		if (doWhat == 'restore')
		{
			var selectIdArr = selectId.split(",");
			var usrResponse = null;
			if (selectIdArr.length > 1)
			{
				alert('Multiple Tickets selected, please select a single Ticket to restore!');						
			}
			else
			{
				var oTicket = ( Tickets[gloListControl.thisRow._index] )? Tickets[gloListControl.thisRow._index] : null;
				if (oTicket.isdeleted == '1')
				{
					usrResponse = confirm('Are you sure you want to restore this ticket?');
				}
				else
				{
					alert('The selected Ticket is not deleted and cannot be restored!');
				}
			}
			if (usrResponse)
			{
				if (docName=="ticketsearchresults.ems" || docName=="contacthistory.ems")
				{
					document.tabularForm.Action.value = doWhat;
					var postResults = glo_buildFormPost('tabularForm');
					//if (postResults[1].indexOf('Refresh')!=-1)
						var reXML = postResults[2];			
						if (reXML.selectSingleNode("/root/UpdateAllCounts"))
						{
							parent.frames.menu.updateTicketCount();
						}
						glo_doReload('ListHolder',window.location.href);
				} else {
					document.tabularForm.Action.value = doWhat;
					var postResults = glo_buildFormPost('tabularForm');
					if (postResults[0]==true)
					{
						var reXML = postResults[2];			
						if (reXML.selectSingleNode("/root/UpdateAllCounts"))
						{
							parent.frames.menu.updateTicketCount();
						}
						var newUrl = "./"+docName+"?TicketBoxView="+ticketboxview+"&CurrentPage="+currentpage;
						glo_doReload('ListHolder',newUrl);
					}
				}
			}
		}
		if (doWhat == 'unlock')
		{
			var selectIdArr = selectId.split(",");
			var usrResponse = null;
			if (selectIdArr.length > 1)
				usrResponse = confirm('Are you sure you want to unlock these tickets?');
			else
				usrResponse = confirm('Are you sure you want to unlock this ticket?');
			if (usrResponse)
			{
				if (docName=="ticketsearchresults.ems")
				{
					document.tabularForm.Action.value = doWhat;
					var postResults = glo_buildFormPost('tabularForm');
					var reXML = postResults[2];			
					if (reXML.selectSingleNode("/root/UpdateAllCounts"))
					{
						parent.frames.menu.updateTicketCount();
					}
					glo_doReload('ListHolder',window.location.href);
				}						
			}
		}
		if (doWhat == 'contact') {
		
			glo_launchModelessWindow('./modalframe.ems?file=multiplecontacts.ems&ticketID='+selectId+'&ticketboxview='+ticketboxview, 400, 400, 'yes', 'no', 'no');
			
			if (listRow.length)
			{
				for (var x = 0; x < listRow.length; x++)
				{
					if (listRow[x].getAttribute("glc_form_tabularForm_selectId")==selectId)
					{					
						listRow[x].focus();
						if (Tickets[x]) Tickets[x].forceUpdate('notes');
					}
				}
			} else {
				if (Tickets[0]) Tickets[0].forceUpdate('notes');
			}
		}
		if (doWhat == 'voipcall')
		{
			glo_launchModelessWindow('./modalframe.ems?file=voipcall.ems&ticket='+selectId, 600, 400, 'yes', 'no', 'no');	
		}
		if (doWhat == 'notes') {
		
			glo_launchModalWindow('./modalframe.ems?file=ticketnotes.ems&ticket='+selectId, 600, 400, 'yes', 'no', 'no');
			if (listRow.length)
			{
				for (var x = 0; x < listRow.length; x++)
				{
					if (listRow[x].glc_form_tabularForm_selectId==selectId)
					{					
						listRow[x].focus();
						if (Tickets[x]) Tickets[x].forceUpdate('notes');
					}
				}
			} else {
				if (Tickets[0]) Tickets[0].forceUpdate('notes');
			}
		}
	}
}
