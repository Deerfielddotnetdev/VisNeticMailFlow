				if(useCutoff == 0)
				{
					if (!noneSelected)
					{
						if(beenRead)
						{
							parent.splitpane.msgframe.onUnRead();
						}
					}
					else
					{
						alert("You must select at least one item!");
					}
				}
			}
		}
	}
	if(theKey == 86 && ctrlPressed)
	{
		if(docName == "mytickets.ems" || docName == "ticketsearchresults.ems" || docName == "ticketlist.ems")
		{
			if (oImg.src.indexOf('minus.gif') != -1)
			{
				if(usePrev)
				{
					if (!noneSelected)
					{
						if(isDraft == 0)
						{
							parent.splitpane.msgframe.changeTicket();
						}
					}
					else
					{
						alert("You must select at least one item!");
					}
				}
				else
				{
					alert("This function is only available when the message\npreview pane is enabled or when you open the\nmessage in a new window!");
				}
			}
		}
	}
	if(docName == "mytickets.ems" || docName == "ticketsearchresults.ems" || docName == "ticketlist.ems")
	{
		if(theKey == 78 && altPressed)
	 	{
	 		if (!noneSelected)
			{
				ticketFunc('notes');
			}
			else
			{
				alert("You must select at least one item!");
			}
		}
		if(theKey == 80 && altPressed)
	 	{
	 		if (!noneSelected)
			{
				ticketProps();
			}
			else
			{
				alert("You must select at least one item!");
			}
		}
		if(theKey == 87 && ctrlPressed)
	 	{
	 		if (!noneSelected)
			{
				closeTicket();
			}
			else
			{
				alert("You must select at least one item!");
			}
		}
	}
	if(docName != "ticketsearchresults.ems")
	{
		if(theKey == 71 && altPressed)
	 	{
		 	if(docName != "outbox.ems")
	 		{
		 		getOldest(1);
			}
		}
		if(theKey == 77 && ctrlPressed)
	 	{
	 		if (singleSelected)
			{
				ticketFunc('addtoticket');
			}
			else
			{
				alert("This function is only available when a single ticket is selected!");
			}
		}
		if(theKey == 78 && ctrlPressed)
	 	{
	 		glo_launchModalWindow('./modalframe.ems?file=newticket.ems$ticketboxview='+ticketboxview, 600, 560, 'yes', 'no', 'no')
	 	}
		if(theKey == 79 && altPressed)
	 	{
	 		if(docName != "outbox.ems" || docName != "sentitems.ems" || docName != "drafts.ems")
	 		{
		 		if (!noneSelected)
				{
					takeOwnership();
				}
				else
				{
					alert("You must select at least one item!");
				}
			}
		}
		if(theKey == 82 && altPressed)
	 	{
	 		if(docName != "outbox.ems" || docName != "sentitems.ems" || docName != "drafts.ems")
	 		{
		 		if (!noneSelected)
				{
					reassignTicket();
				}
				else
				{
					alert("You must select at least one item!");
				}
			}
			else
			{
				if (singleSelected)
				{
					ticketFunc('revoke');
				}
				else
				{
					alert("This function is only available when a single ticket is selected!");
				}
			}
		}
		if(theKey == 84 && ctrlPressed)
	 	{
	 		if(docName != "outbox.ems" || docName != "sentitems.ems" || docName != "drafts.ems")
	 		{
	 			glo_launchMsgCompWindow(null, null, ticketboxview, ticketboxid, null, null, null);
	 		}
	 		else
	 		{
	 			ticketFunc('new');
	 		}
	 	}
	 }
	if(docName == "ticketsearchresults.ems")
	{
		if(theKey == 82 && ctrlPressed)
	 	{
	 		if (!noneSelected)
			{
				ticketFunc('restore');
			}
			else
			{
				alert("You must select at least one item!");
			}
		}
	}
	if(theKey == 112 && altPressed)
	{
    		switch (docName)
		{
			case "ticketsearchresults.ems":
				openHelp('Overview/Tickets.htm')
				break;
			case "mytickets.ems":
				openHelp('My_Shortcuts/My_Tickets.htm');
				break;
			case "ticketlist.ems":
				openHelp('Overview/Tickets.htm');
				break;
			case "outbox.ems":	
				openHelp('My_Shortcuts/outbox.htm');
				break;
			case "sentitems.ems":	
				openHelp('My_Shortcuts/sent_items.htm');
				break;
			case "drafts.ems":	
				openHelp('My_Shortcuts/drafts.htm');
				break;
		}
   	}
 	if(theKey == 116 && altPressed)
	{
		document.location.reload();
	}
return false;
}