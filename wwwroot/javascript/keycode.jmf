						var ticketID = oTicket.ticketid;
						for(var i = 0; i < Tickets.length; i++)
						{
							if(Tickets[i].ticketid == ticketID)
							{
								TicketObj = Tickets[i];
								break;
							}
						}		
							
						if(TicketObj)
						{
							var treeId = 'threadTree' + ticketID;
							var seqId = 'sequenceTree' + ticketID;
							var obj = document.getElementById(treeId);
							if(obj == null)
							{
								obj = document.getElementById(seqId);		
							}
							if(obj != null)
							{
								var type = obj.getAttribute('type');
								var MsgObj = TicketObj.whatsSelected;
								if(type == 'threaded')
								{
									var numMsgs = TicketObj.threadedMsg.length;
									for(var i = 0; i < TicketObj.threadedMsg.length; i++)
									{
										MsgObj = TicketObj.threadedMsg[i];
										if(MsgObj == TicketObj.whatsSelected)
										{
											myRow = i;	
										}
									}
								}
								else
								{
									var numMsgs = TicketObj.sequenceMsg.length;
									
									for(var i = 0; i < TicketObj.sequenceMsg.length; i++)
									{
										MsgObj = TicketObj.sequenceMsg[i];
										if(MsgObj == TicketObj.whatsSelected)
										{
											myRow = i;	
										}
										
									}
								}
																	
								if(myRow < numMsgs - 1)
								{
									var nextRow = ++myRow;
									if(type == 'threaded')
									{
										
										TicketObj.threadedMsg[nextRow].msgRow.focus();
										TicketObj.threadedMsg[nextRow].msgRow.click();
									}
									else
									{
										TicketObj.sequenceMsg[nextRow].msgRow.focus();
										TicketObj.sequenceMsg[nextRow].msgRow.click();
									}
								}
							}
						}
						
					}
					else
					{
						if(gloListControl.starRowId != listRow.length - 1)
		 				{
							var elem = window.event.srcElement;
						 	while (elem.parentElement.tagName != "TABLE")
							{
								if (elem.tagName == "TR")
								{
									var i = elem.tabRowId;
									i=++i;
									listRow[i].focus();
									listRow[i].click();
									break;
								}
								elem = elem.parentElement;
							}
						}
					}
				}
			
		 }
		else
		{
			alert("This function is only available when a single ticket is selected!");
		}
