											<img src="images/ico_11x_effective.gif" width="11" height="11" border="0"/>					
											<span class="leftmenuNoHiLight" id="spanEffectiveRights" onclick="UpdateAdminLink(id);" style="padding-left:4px;">Effective Rights</span>
											</a>
										</nobr>
									</div>									
								</div>
							</div>
							<div class="branch">
								<table style="margin-bottom:3px;" onclick="toggleTree('_adm_spell');" border="0" cellpadding="0" cellspacing="0">
									<tr>
										<td width="11" valign="top">				
											<img id="img_adm_spell" src="./images/minus.gif" width="11" height="11" border="0"/>
										</td>
										<td class="adminbranch" valign="top">
											<nobr><span style="font-weight:bold;">Spell Checking</span></nobr>
										</td>
									</tr>
								</table>
								<div id="div_adm_spell" class="branch">
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
											<a class="adminMenu" href="#" onclick="setRightPane('customdictionary.ems?agentid=0');">
												<img src="images/ico_globaldictionary_11x.gif" width="11" height="11" border="0" />
												<span class="leftmenuNoHiLight" id="spanGlobalDictionary" onclick="UpdateAdminLink(id);" style="padding-left:4px;">Global Dictionary</span>
											</a>
										</nobr>
									</div>
								</div>
							</div>
							<div class="branch">
								<table style="margin-bottom:3px;" onclick="toggleTree('_adm_tb');" border="0" cellpadding="0" cellspacing="0">
									<tr>
										<td width="11" valign="top">				
											<img id="img_adm_tb" src="./images/minus.gif" width="11" height="11" border="0"/>
										</td>
										<td class="adminbranch" valign="top">
											<nobr><span style="font-weight:bold;">TicketBoxes</span></nobr>
										</td>
									</tr>
								</table>
								<div id="div_adm_tb" class="branch">
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
											<a class="adminMenu" href="#" onclick="setRightPane('ticketboxes.ems?msg=5');">
												<img src="images/ico_myshortcuts_public.gif" width="11" height="11" border="0"/>					
												<span class="leftmenuNoHiLight" id="spanTicketBoxes" onclick="UpdateAdminLink(id);" style="padding-left:4px;">TicketBoxes</span>
											</a>
										</nobr>
									</div>
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
											<a class="adminMenu" href="#" onclick="setRightPane('ticketboxheaders.ems');">
												<img src="images/ico_admin_ticketboxheaders.gif" width="11" height="11" border="0"/>					
												<span class="leftmenuNoHiLight" id="spanTicketBoxHeaders" onclick="UpdateAdminLink(id);" style="padding-left:4px;">TicketBox Headers</span>
											</a>
										</nobr>
									</div>
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
											<a class="adminMenu" href="#" onclick="setRightPane('ticketboxfooters.ems');">
												<img src="images/ico_admin_ticketboxfooters.gif" width="11" height="11" border="0"/>					
												<span class="leftmenuNoHiLight" id="spanTicketBoxFooters" onclick="UpdateAdminLink(id);" style="padding-left:4px;">TicketBox Footers</span>
											</a>
										</nobr>
									</div>
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
											<a class="adminMenu" href="#" onclick="setRightPane('ticketboxowners.ems');">
												<img src="images/ico_admin_agents.gif" width="11" height="11" border="0"/>					
												<span class="leftmenuNoHiLight" id="spanTicketBoxOwners" onclick="UpdateAdminLink(id);" style="padding-left:4px;">TicketBox Owners</span>
											</a>
										</nobr>
									</div>
								</div>
							</div>
							<div class="branch">
								<table style="margin-bottom:3px;" onclick="toggleTree('_adm_tik');" border="0" cellpadding="0" cellspacing="0">
									<tr>
										<td width="11" valign="top">				
											<img id="img_adm_tik" src="./images/minus.gif" width="11" height="11" border="0"/>
										</td>
										<td class="adminbranch" valign="top">
											<nobr><span style="font-weight:bold;">Tickets</span></nobr>
										</td>
									</tr>
								</table>
								<div id="div_adm_tik" class="branch">
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
											<a class="adminMenu" href="#" onclick="setRightPane('ticketfields.ems');">
												<img src="images/ico_myshortcuts_public.gif" width="11" height="11" border="0"/>					
												<span class="leftmenuNoHiLight" id="spanTicketFields" onclick="UpdateAdminLink(id);" style="padding-left:4px;">Custom Ticket Fields</span>
											</a>
										</nobr>
									</div>
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
											<a class="adminMenu" href="#" onclick="setRightPane('ticketcategories.ems');">
												<img src="images/ico_myshortcuts_public.gif" width="11" height="11" border="0"/>					
												<span class="leftmenuNoHiLight" id="spanTicketCategories" onclick="UpdateAdminLink(id);" style="padding-left:4px;">Ticket Categories</span>
											</a>
										</nobr>
									</div>
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
											<a class="adminMenu" href="#" onclick="setRightPane('ticketsearchresults.ems?Action=search&amp;hideleft=0&amp;ticketlockstateid=0');">
												<img src="images/ico_myshortcuts_public.gif" width="11" height="11" border="0"/>					
												<span class="leftmenuNoHiLight" id="spanLockedTickets" onclick="UpdateAdminLink(id);" style="padding-left:4px;">Locked Tickets</span>
											</a>
										</nobr>
									</div>
								</div>
							</div>												
						</div>
					</td>
				</tr>
			</table>
			</div>			
			</xsl:if>		
			
					<!--
					#X# CLOSE CONTENT AREA FOR ADMINISTRATION OPTIONS
					-->
			</div>
			</td>
		</tr>
		<tr>
			<td style="width:100%">
				<div id="0rollUpBtnX" style="cursor:hand;width:100%;border:1px outset;" onclick="docRollUpClick(0);" class="menuColor">
				<table width="100%" border="0" cellpadding="0" cellspacing="0">
					<tr>
						<script language="JavaScript" type="text/javascript">
							var xMenuX = new Array();
								xMenuX[0] = new Array();
								xMenuX[0][0] = new xMenuObject();
								xMenuX[0][1] = new xMenuItem('<img src="images/ico_as1.gif" width="11" height="11" border="0" valign="bottom"/>', '', 1, null, null, 'StatusMenuHolderX');
								xMenuX[1] = new Array();
								xMenuX[1][0] = new xMenuObject();
								xMenuX[1][1] = new xMenuItem('<img src="images/ico_as1.gif" width="11" height="11" border="0"/>&amp;nbsp;Online&amp;nbsp;', "setStatus('1');", 0);
								xMenuX[1][2] = new xMenuItem('<img src="images/ico_as2.gif" width="11" height="11" border="0"/>&amp;nbsp;Away&amp;nbsp;', "setStatus('2');", 0);
								xMenuX[1][3] = new xMenuItem('<img src="images/ico_as3.gif" width="11" height="11" border="0"/>&amp;nbsp;Not Available&amp;nbsp;', "setStatus('3');", 0);
								xMenuX[1][4] = new xMenuItem('<img src="images/ico_as5.gif" width="11" height="11" border="0"/>&amp;nbsp;Offline&amp;nbsp;', "setStatus('5');", 0);
								xMenuX[1][5] = new xMenuItem('<img src="images/ico_as6.gif" width="11" height="11" border="0"/>&amp;nbsp;Out of Office&amp;nbsp;', "setStatus('6');", 0);
						</script>
						<td id="StatusMenuHolderX" title="Online - Click to set status" style="padding-bottom:2px;width:11px;"></td>
						<td style="padding:0px 0px 2px 2px;align:left;"><xsl:value-of select="/root/user/name"/></td>
					</tr>
				</table>
				</div>
			<xsl:if test="not(/root/user/access/stdreports &lt; 2)">	
				<div id="1rollUpBtnX" style="cursor:hand;width:100%;border:1px outset;" onclick="docRollUpClick(1);" class="menuColor">
				<table width="100%" border="0" cellpadding="0" cellspacing="0"><tr><td style="padding:2px 0px 2px 5px;">
				<img src="images/ico_admin_logging.gif" width="11" height="11" border="0"/>
				<nobr><span style="margin-left:7px;">Reporting</span></nobr>
				</td></tr></table>
				</div>
			</xsl:if>	
			<xsl:if test="/root/user/isadmin = 1">
				<div id="2rollUpBtnX" style="cursor:hand;width:100%;border:1px outset;" onclick="docRollUpClick(2);" class="menuColor">
				<table width="100%" border="0" cellpadding="0" cellspacing="0"><tr><td style="padding:2px 0px 2px 5px;">
				<img src="images/ico_admin_settings.gif" width="11" height="11" border="0"/>
				<nobr><span style="margin-left:7px;">Administration</span></nobr>
				</td></tr></table>
				</div>
			</xsl:if>
			</td>
		</tr>
	</table>
	<form name="expandall" action="">
		<input type="hidden" value="1" id="expand"/>
	</form>
	</body>
	<script type="text/javascript">
		if (document.getElementById("0rollUpBtn"))
		{
			var iLastb = null;
			var icount = 0;
			
			<xsl:choose>
			<xsl:when test="/root/user/isadmin = 1">
			icount = 3;
			</xsl:when>
			<xsl:when test="/root/user/access/stdreports &lt; 2">
			icount = 1;
			</xsl:when>
			<xsl:otherwise>
			icount = 2;
			</xsl:otherwise>
			</xsl:choose>
			
			var bin = null;
			
			if(document.cookie &amp;&amp; getCookieCount("leftmenuBtn") != 0)
			{
				iLastb = getCookieNum("leftmenuBtn", getCookieCount("leftmenuBtn"));
			}
			
			if(iLastb == null)
			{
				iLastb = 0;
			}
			
			if(isNaN(iLastb) == false)
			{
				for (var x = 0; x &lt; icount; x++)
				{
					var idName = x + "rollUpBtn";
					var idNameX = x + "rollUpBtnX";
					var idContent = x + "rollUpContent";
					var irb = document.getElementById(idName);
					var xrb = document.getElementById(idNameX);
					var ruc = document.getElementById(idContent);
					
					if(x &lt; iLastb)
					{
						irb.style.display = "block";
						xrb.style.display = "none";
					}
					if(x == iLastb)
					{
						irb.style.display = "block";
						xrb.style.display = "none";
						ruc.style.display = "block";
					}
					if(x &gt; iLastb)
					{
						irb.style.display = "none";
						xrb.style.display = "block";
					}
				}				
				rcOpenDim = iLastb;
			}
			
		}
	</script>
	</html>
</xsl:template>
</xsl:stylesheet>