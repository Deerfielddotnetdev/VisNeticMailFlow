											<a class="adminMenu" href="#" onclick="setRightPane('securitysettings.ems');">
												<img src="images/ico_admin_settings.gif" width="11" height="11" border="0"/>					
												<span class="leftmenuNoHiLight" id="spanOtherRestrictions" onclick="UpdateAdminLink(id);" style="padding-left:4px;">Other Restrictions</span>
											</a>
										</nobr>
									</div>
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
