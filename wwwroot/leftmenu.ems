									</div>
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
											<a class="adminMenu" href="#" onclick="setRightPane('accesscontrol.ems');">
												<img src="images/ico_admin_accesscontrol.gif" width="11" height="11" border="0"/>					
												<span class="leftmenuNoHiLight" id="spanCustomAccessControl" onclick="UpdateAdminLink(id);" style="padding-left:4px;">Custom Access Control</span>
											</a>
										</nobr>
									</div>
									<div class="mainbranch" wrap="off" style="margin-left:16px;margin-bottom:3px;">
										<nobr>
