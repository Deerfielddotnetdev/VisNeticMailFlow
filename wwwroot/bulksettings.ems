																			</tr>
																			<tr>
																				<td class="subSectionHeader" colspan="2">General Settings</td>
																			</tr>
																			<tr>
																				<td class="subSectionWrapper" colspan="2" style="padding-top:0px!important;">
																					<table border="0" cellspacing="0" cellpadding="0" style="width:100%;padding-left:5px;padding-right:5px;">
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input style="padding-bottom:10px;" type="checkbox" name="tb_owner" onclick="enableTBForm();"/>TicketBox Owner:</td>
																							<td style="padding-left:10px;padding-top:5px;width:100%;" valign="bottom">
																								<select id="owner" disabled="true" name="OwnerID">
																									<option value="0">-- NONE --</option>
																									<xsl:for-each select="/root/TicketBoxOwners/TicketBoxOwner">
																										<option>
																											<xsl:attribute name="value"><xsl:value-of select="@ID"/></xsl:attribute>
																											<xsl:value-of select="@Description"/>
																										</option>
																									</xsl:for-each>
																								</select>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="tb_msgdest" onclick="enableTBForm();"/>Message Destination:</td>
																							<td style="padding-left:10px;padding-top:5px;width:100%;" valign="bottom">
																								<select id="msgdest" disabled="true" name="MsgDestID">
																									<xsl:for-each select="root/MessageDestinations/MessageDestination">
																										<option>
																											<xsl:attribute name="value"><xsl:value-of select="@ID"/></xsl:attribute>
																											<xsl:value-of select="@Address" disable-output-escaping="yes"/>
																										</option>
																									</xsl:for-each>
																								</select>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="tb_getold" onclick="enableTBForm();"/>Require Get Oldest:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="getold" disabled="true" type="checkbox" name="TBGetOld"/>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="tb_reqtc" onclick="enableTBForm();"/>Require TicketCategory Selection before Message Send:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="reqtc" disabled="true" type="checkbox" name="RequireTC"/>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="tb_globalunread" onclick="enableTBForm();"/>Use Global Unread Mode:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="globalunread" disabled="true" type="checkbox" name="GlobalUnread"/>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="tb_multi" onclick="enableTBForm();"/>Enable MultiMail for New Outbound Messages:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="multi" disabled="true" type="checkbox" name="MultiMail"/>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="tb_fromadd" onclick="enableTBForm();"/>Default From Address Format:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<select id="fromadd" disabled="true" name="fromFormat">
																									<option value="0">"TicketBox Email Name" &lt;TicketBox Email Address&gt;</option>
																									<option value="1">"Agent Name" &lt;TicketBox Email Address&gt;</option>
																									<option value="2">"Agent Name" &lt;Agent Email Address&gt;</option>
																								</select>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="tb_linking" onclick="enableTBForm();"/>Ticket Linking:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<select id="linking" disabled="true" name="TicketLink">
																									<option value="0">Do not allow Ticket Linking</option>
																									<option value="1">Allow Ticket Linking to other Tickets in this TicketBox</option>
																									<option value="2">Allow Ticket Linking to Tickets in any TicketBox</option>
																								</select>
																							</td>
																						</tr>
																					</table>
																				</td>
																			</tr>
																		</table>
																	</td>
																</tr>
															</table>
