																						<tr>
																							<td style="padding-right:5px;width:100%;" valign="top">
																								<table>
																									<tr>
																										<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;" valign="top">
																											<input type="button" name="btnApplyMS" style="padding-left:2px;padding-right:3px;" class="childControlBtn" value="Apply" onclick="applyMS();"/><span style="padding-top:10px;"><xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;Message Source Settings to:<xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;</span>
																										</td>
																										<td style="padding-top:5px;width:100%;" valign="bottom">
