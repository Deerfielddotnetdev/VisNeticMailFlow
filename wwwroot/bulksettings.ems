											<div id="content5" style="overflow:auto;display:none;visibility:hidden;width:100%;height:100%;">
	  										<table style="width:100%;padding:10px;" border="0" cellspacing="0" cellpadding="0">
													<tr>
														<td>
															<table width="100%;" border="0" cellspacing="0" cellpadding="0">
																<tr>
																	<td style="padding-right:10px;">
																		<table cellspacing="0" border="0" width="100%">
																			<tr>
																				<td width="100%" colspan="2" class="subSectionHeader" align="left">
																					Select Message Destination
																				</td>
																			</tr>
																			<tr>
																				<td width="100%" style="padding-left:10px;" class="subSectionWrapper" colspan="2" align="left">
																					<table border="0" width="100%" cellpadding="0" cellspacing="0">
																						<tr>
																							<td style="padding-right:5px;width:100%;" valign="top">
																								<table>
																									<tr>
																										<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;" valign="top">
																											<input type="button" name="btnApplyMD" style="padding-left:2px;padding-right:3px;" class="childControlBtn" value="Apply" onclick="applyMD();"/><span style="padding-top:10px;"><xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;Message Destination Settings to:<xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;</span>
																										</td>
																										<td style="padding-top:5px;width:100%;" valign="bottom">
																											<select id="MessageDestinationID" name="MessageDestinationID" style="width:300px;">
																												<xsl:attribute name="multiple">true</xsl:attribute>
																												<xsl:attribute name="size">5</xsl:attribute>
																												<option>
																													<xsl:attribute name="value">-1</xsl:attribute>
																													<xsl:attribute name="selected">true</xsl:attribute>
																													Select One, Many or All Message Destination(s)
																												</option>
																												<option>
																													<xsl:attribute name="value">0</xsl:attribute>
																													All Message Destinations
																												</option>
																											<xsl:for-each select="/root/MessageDestinations/MessageDestination">
																												<option>
																													<xsl:attribute name="value"><xsl:value-of select="@ID"/></xsl:attribute>
																													<xsl:value-of select="@Address"/>
																												</option>
																											</xsl:for-each>
																										</select>
																										</td>
																									</tr>
																								</table>
																							</td>
																						</tr>
																					</table>
																				</td>
																			</tr>
																			<tr>
																				<td colspan="2" height="10"><xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;</td>
																			</tr>
																			<tr>
																				<td class="subSectionHeader" colspan="2">Settings</td>
																			</tr>
																			<tr>
																				<td class="subSectionWrapper" colspan="2" style="padding-top:0px!important;">
																					<table border="0" cellspacing="0" cellpadding="0" style="width:100%;padding-left:5px;padding-right:5px;">
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="md_mdenabled" onclick="enableMDForm();"/>Enabled:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="mdenabled" disabled="true" type="checkbox" name="mdEnabled"/>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="md_delinterval" onclick="enableMDForm();"/>Delivery Interval:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="delinterval" disabled="true" size="5" maxlength="4" type="text" name="delInterval" value="2" />
																								minute(s)
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="md_mdofficehrs" onclick="enableMDForm();"/>Only Deliver During Office Hours:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="mdofficehrs" disabled="true" type="checkbox" name="mdOfficeHrs"/>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="md_mdtimeout" onclick="enableMDForm();"/>Connection Timeout:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="mdtimeout" disabled="true" size="5" maxlength="4" type="text" name="mdTimeout" value="10" />
																								second(s)
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="md_mdmaxsize" onclick="enableMDForm();"/>Max Message Size:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="mdmaxsize" disabled="true" size="5" maxlength="6" type="text" name="mdMaxSize" value="5000" />
																								kilobyte(s)
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="md_retry" onclick="enableMDForm();"/>Retry Send:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="retry" disabled="true" size="5" maxlength="4" type="text" name="retrySend" value="0" />
																								hr(s)
																							</td>
																						</tr>
																					</table>
																				</td>
																			</tr>
																		</table>
																	</td>
																</tr>
															</table>
														</td>
													</tr>	
												</table>
											</div>
										</div>
									</td>
								</tr>
							</table>
						</td>
					</tr>
				</table>
			</div>
		</td>
	</tr>
</table>
</form>
<script type="text/javascript">
	document.frmBulkSettings.action.value = "none";
</script>
</body>
</html>
</xsl:template>
</xsl:stylesheet>