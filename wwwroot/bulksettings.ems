																												<option>
																													<xsl:attribute name="value">-1</xsl:attribute>
																													<xsl:attribute name="selected">true</xsl:attribute>
																													Select One, Many or All Message Source(s)
																												</option>
																												<option>
																													<xsl:attribute name="value">0</xsl:attribute>
																													All Message Sources
																												</option>
																											<xsl:for-each select="/root/MessageSources/MessageSource">
																												<option>
																													<xsl:attribute name="value"><xsl:value-of select="@ID"/></xsl:attribute>
																													<xsl:value-of select="@Address"/>
																												</option>
																											</xsl:for-each>
																										</select>
																										</td>
																									</tr>
																								</table>
																							</td>
																						</tr>
																					</table>
																				</td>
																			</tr>
																			<tr>
																				<td colspan="2" height="10"><xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;</td>
																			</tr>
																			<tr>
																				<td class="subSectionHeader" colspan="2">Settings</td>
																			</tr>
																			<tr>
																				<td class="subSectionWrapper" colspan="2" style="padding-top:0px!important;">
																					<table border="0" cellspacing="0" cellpadding="0" style="width:100%;padding-left:5px;padding-right:5px;">
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="ms_msenabled" onclick="enableMSForm();"/>Enabled:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="msenabled" disabled="true" type="checkbox" name="msEnabled"/>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="ms_lvcopies" onclick="enableMSForm();"/>Leave Copies On Server:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="lvcopies0" disabled="true" type="checkbox" name="lvCopies"/>
																								for
																								<input id="lvcopies1" disabled="true" size="5" maxlength="4" type="text" name="leaveCopiesDays" value="0" />
																								day(s)
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="ms_skipdownload" onclick="enableMSForm();"/>Ignore Messages Older Than:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="skipdownload" disabled="true" size="5" maxlength="4" type="text" name="skipDownloadDays" value="7" />
																								day(s)
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="ms_ignoredups" onclick="enableMSForm();"/>Ignore Duplicate Messages:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="ignoredups" disabled="true" type="checkbox" name="ignoreDups"/>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="ms_msofficehrs" onclick="enableMSForm();"/>Only Collect During Office Hours:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="msofficehrs" disabled="true" type="checkbox" name="msOfficeHrs"/>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="ms_usereplyto" onclick="enableMSForm();"/>Use "Reply-To:" email address as contact address:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="usereplyto" disabled="true" type="checkbox" name="useReplyTo"/>
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="ms_ckinterval" onclick="enableMSForm();"/>Check Interval:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="ckinterval" disabled="true" size="5" maxlength="4" type="text" name="ckInterval" value="2" />
																								minute(s)
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="ms_mstimeout" onclick="enableMSForm();"/>Connection Timeout:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="mstimeout" disabled="true" size="5" maxlength="4" type="text" name="msTimeout" value="75" />
																								second(s)
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="ms_msmaxsize" onclick="enableMSForm();"/>Max Message Size:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="msmaxsize" disabled="true" size="5" maxlength="6" type="text" name="msMaxSize" value="5000" />
																								kilobyte(s)
																							</td>
																						</tr>
																						<tr style="padding-top:10px;">
																							<td nowrap="true" style="padding-left:10px;padding-top:5px;width:380px;"><input type="checkbox" name="ms_zipattach" onclick="enableMSForm();"/>Zip Attachments Threshold:</td>
																							<td align="left" style="padding-left:10px;width:100%;">
																								<input id="zipattach" disabled="true" size="5" maxlength="4" type="text" name="zipAttach" value="0" />
