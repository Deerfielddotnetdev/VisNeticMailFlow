																											<input type="button" name="btnApplyRR" style="padding-left:2px;padding-right:3px;" class="childControlBtn" value="Apply" onclick="applyRR();"/><span style="padding-top:10px;"><xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;Routing Rule Settings to:<xsl:text disable-output-escaping="yes">&amp;</xsl:text>#160;</span>
																										</td>
