		[default] interface IRoutingEngineComm;
	};
	[
		uuid(772926AD-F557-4010-A92C-E0DA95CB0AC6),
		helpstring("RoutingEngineAdmin Class")
	]
	coclass RoutingEngineAdmin
	{
